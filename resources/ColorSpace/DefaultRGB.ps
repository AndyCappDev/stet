%!PS-Adobe-3.0 Resource-ColorSpace
%%Title: DefaultRGB
%%EndComments

% Default CIE substitute for DeviceRGB when UseCIEColor is true.
% PLRM Section 6.2.5: DefaultRGB must be CIEBasedABC, CIEBasedDEF,
% or [/DeviceRGB].
% Uses CIEBasedABC with sRGB primaries and D65 white point.

[
    /CIEBasedABC
    <<
        /WhitePoint [0.9505 1.0000 1.0890]  % D65 illuminant
        /BlackPoint [0.0000 0.0000 0.0000]

        /RangeABC [0.0 1.0 0.0 1.0 0.0 1.0]

        % DecodeABC: sRGB gamma linearization (R,G,B → linear R,G,B)
        /DecodeABC [
            { dup 0.04045 lt
                { 12.92 div }
                { 0.055 add 1.055 div 2.4 exp }
            ifelse } bind
            { dup 0.04045 lt
                { 12.92 div }
                { 0.055 add 1.055 div 2.4 exp }
            ifelse } bind
            { dup 0.04045 lt
                { 12.92 div }
                { 0.055 add 1.055 div 2.4 exp }
            ifelse } bind
        ]

        % MatrixABC: sRGB primaries → XYZ (D65)
        /MatrixABC [
            0.4124 0.2126 0.0193
            0.3576 0.7152 0.1192
            0.1805 0.0722 0.9505
        ]

        /RangeLMN [0.0 0.9505 0.0 1.0000 0.0 1.0890]
    >>
]
