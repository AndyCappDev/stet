%!PS-Adobe-2.0
%%BoundingBox: 0 0 160 84

newpath
0 0 moveto
160 0 lineto
0 84 rlineto
0 84 lineto
clip

80 5 translate

72 dup scale
1 72 div setlinewidth

gsave
0.7 setgray
newpath
-1 1 1 { /i exch def
i -1.25 moveto
i  1.25 lineto
-1.25 i moveto
 1.25 i lineto
} for
stroke
grestore

/N 100 def
newpath
/x -1.25 def
/dx 2.5 N div def
x dup dup mul moveto
N {
  /x x dx add def
  x dup dup mul lineto
} repeat
stroke


