%!PS-Adobe-3.0
%%Title: Pattern Fill Test
%%BoundingBox: 0 0 612 792
%%EndComments

% === Test 1: Simple colored pattern (PaintType 1) — checkerboard ===
/Times-Roman findfont 14 scalefont setfont
50 750 moveto (Test 1: Colored pattern - checkerboard) show

<< /PatternType 1
   /PaintType 1
   /TilingType 1
   /BBox [0 0 20 20]
   /XStep 20
   /YStep 20
   /PaintProc { pop
     1 0 0 setrgbcolor 0 0 10 10 rectfill
     0 0 1 setrgbcolor 10 10 10 10 rectfill
   }
>> matrix makepattern setpattern
50 680 moveto 200 0 rlineto 0 60 rlineto -200 0 rlineto closepath fill

% === Test 2: Colored pattern with strokes (crosshatch) ===
50 650 moveto 0 setgray (Test 2: Colored pattern - crosshatch) show

<< /PatternType 1
   /PaintType 1
   /TilingType 1
   /BBox [0 0 12 12]
   /XStep 12
   /YStep 12
   /PaintProc { pop
     0.9 0.9 1 setrgbcolor 0 0 12 12 rectfill
     0 0 0.5 setrgbcolor
     0.5 setlinewidth
     0 0 moveto 12 12 lineto stroke
     12 0 moveto 0 12 lineto stroke
   }
>> matrix makepattern setpattern
50 580 moveto 200 0 rlineto 0 60 rlineto -200 0 rlineto closepath fill

% === Test 3: Colored pattern with curves ===
50 550 moveto 0 setgray (Test 3: Colored pattern - circles) show

<< /PatternType 1
   /PaintType 1
   /TilingType 1
   /BBox [0 0 24 24]
   /XStep 24
   /YStep 24
   /PaintProc { pop
     1 1 0.8 setrgbcolor 0 0 24 24 rectfill
     0.8 0 0 setrgbcolor
     1 setlinewidth
     12 12 8 0 360 arc stroke
   }
>> matrix makepattern setpattern
50 480 moveto 200 0 rlineto 0 60 rlineto -200 0 rlineto closepath fill

% === Test 4: Pattern with scaled matrix ===
50 450 moveto 0 setgray (Test 4: Colored pattern - scaled 2x) show

<< /PatternType 1
   /PaintType 1
   /TilingType 1
   /BBox [0 0 10 10]
   /XStep 10
   /YStep 10
   /PaintProc { pop
     0 0.6 0.3 setrgbcolor 0 0 10 10 rectfill
     1 1 1 setrgbcolor 0 0 5 5 rectfill
   }
>> [2 0 0 2 0 0] makepattern setpattern
50 380 moveto 200 0 rlineto 0 60 rlineto -200 0 rlineto closepath fill

% === Test 5: Pattern with rotated matrix ===
50 350 moveto 0 setgray (Test 5: Colored pattern - rotated 30 deg) show

<< /PatternType 1
   /PaintType 1
   /TilingType 1
   /BBox [0 0 15 15]
   /XStep 15
   /YStep 15
   /PaintProc { pop
     0.6 0.6 1 setrgbcolor 0 0 15 15 rectfill
     0.2 0.2 0.8 setrgbcolor
     1 setlinewidth
     0 0 moveto 15 0 lineto stroke
     0 7.5 moveto 15 7.5 lineto stroke
   }
>>
% 30 degree rotation matrix
30 cos 30 sin 30 sin neg 30 cos 0 0 6 array astore
makepattern setpattern
50 280 moveto 200 0 rlineto 0 60 rlineto -200 0 rlineto closepath fill

% === Test 6: Pattern with eofill ===
50 250 moveto 0 setgray (Test 6: Colored pattern - eofill star) show

<< /PatternType 1
   /PaintType 1
   /TilingType 1
   /BBox [0 0 16 16]
   /XStep 16
   /YStep 16
   /PaintProc { pop
     0 0.7 0 setrgbcolor 0 0 16 16 rectfill
     1 1 0 setrgbcolor
     2 setlinewidth 0 8 moveto 16 8 lineto stroke
     8 0 moveto 8 16 lineto stroke
   }
>> matrix makepattern setpattern
% 5-pointed star using eofill — skip-vertex winding
% Center (150,160), radius 70
150 230 moveto
193.3 95.4 lineto
83.0 203.5 lineto
217.0 203.5 lineto
106.7 95.4 lineto
closepath eofill

% === Test 12: Pattern fill via rectfill ===
300 220 moveto 0 setgray (Test 12: Colored pattern via rectfill) show

<< /PatternType 1
   /PaintType 1
   /TilingType 1
   /BBox [0 0 8 8]
   /XStep 8
   /YStep 8
   /PaintProc { pop
     0.9 0.7 0.3 setrgbcolor 0 0 8 8 rectfill
     0.4 0.2 0 setrgbcolor
     0 0 4 4 rectfill
     4 4 4 4 rectfill
   }
>> matrix makepattern setpattern
300 150 200 60 rectfill

% === Test 7: Two different patterns on one page (dedup test) ===
300 750 moveto 0 setgray (Test 7: Two patterns side by side) show

% Pattern A - horizontal stripes
<< /PatternType 1
   /PaintType 1
   /TilingType 1
   /BBox [0 0 20 6]
   /XStep 20
   /YStep 6
   /PaintProc { pop
     1 1 1 setrgbcolor 0 0 20 6 rectfill
     0 0 0.6 setrgbcolor 0 0 20 3 rectfill
   }
>> matrix makepattern setpattern
300 680 moveto 90 0 rlineto 0 60 rlineto -90 0 rlineto closepath fill

% Pattern B - vertical stripes
<< /PatternType 1
   /PaintType 1
   /TilingType 1
   /BBox [0 0 6 20]
   /XStep 6
   /YStep 20
   /PaintProc { pop
     1 1 1 setrgbcolor 0 0 6 20 rectfill
     0.6 0 0 setrgbcolor 0 0 3 20 rectfill
   }
>> matrix makepattern setpattern
410 680 moveto 90 0 rlineto 0 60 rlineto -90 0 rlineto closepath fill

% === Test 8: Pattern with complex PaintProc (fills + strokes + arcs) ===
300 650 moveto 0 setgray (Test 8: Complex PaintProc) show

<< /PatternType 1
   /PaintType 1
   /TilingType 1
   /BBox [0 0 20 20]
   /XStep 20
   /YStep 20
   /PaintProc { pop
     0.2 0.6 0.8 setrgbcolor 0 0 20 20 rectfill
     1 1 1 setrgbcolor
     10 10 7 0 360 arc fill
     0.2 0.2 0.2 setrgbcolor
     0.5 setlinewidth
     10 10 7 0 360 arc stroke
   }
>> matrix makepattern setpattern
300 580 moveto 200 0 rlineto 0 60 rlineto -200 0 rlineto closepath fill

% === Test 9: Same pattern used twice (dedup test) ===
300 550 moveto 0 setgray (Test 9: Same pattern reused - dedup) show

/mypattern << /PatternType 1
   /PaintType 1
   /TilingType 1
   /BBox [0 0 10 10]
   /XStep 10
   /YStep 10
   /PaintProc { pop
     0.8 0.8 0.8 setrgbcolor 0 0 10 10 rectfill
     0 0 0 setrgbcolor
     0.5 setlinewidth
     0 0 moveto 10 10 lineto stroke
   }
>> matrix makepattern def

mypattern setpattern
300 480 moveto 90 0 rlineto 0 60 rlineto -90 0 rlineto closepath fill
mypattern setpattern
410 480 moveto 90 0 rlineto 0 60 rlineto -90 0 rlineto closepath fill

% === Test 10: Pattern with gsave/grestore around it ===
300 450 moveto 0 setgray (Test 10: Pattern in gsave/grestore) show

gsave
<< /PatternType 1
   /PaintType 1
   /TilingType 1
   /BBox [0 0 14 14]
   /XStep 14
   /YStep 14
   /PaintProc { pop
     0.5 0 0.5 setrgbcolor 0 0 14 14 rectfill
     1 1 1 setrgbcolor 7 0 7 14 rectfill
   }
>> matrix makepattern setpattern
300 380 moveto 200 0 rlineto 0 60 rlineto -200 0 rlineto closepath fill
grestore

% === Test 11: Clipped pattern fill ===
300 335 moveto 0 setgray (Test 11: Clipped pattern fill) show

gsave
% Circular clip
400 280 40 0 360 arc clip newpath

<< /PatternType 1
   /PaintType 1
   /TilingType 1
   /BBox [0 0 10 10]
   /XStep 10
   /YStep 10
   /PaintProc { pop
     1 0.5 0 setrgbcolor 0 0 10 10 rectfill
     0 0 0 setrgbcolor
     5 5 4 0 360 arc fill
   }
>> matrix makepattern setpattern
300 240 200 80 rectfill
grestore

% === Labels ===
0 setgray
/Times-Roman findfont 10 scalefont setfont
50 65 moveto (Pattern Fill Test Suite - 12 tests) show

showpage
%%EOF
