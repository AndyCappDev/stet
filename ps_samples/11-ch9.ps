% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

% - Inserting box.inc ----------------------

% box.inc

/box {
2 dict begin

/h exch def
/w exch def

0 0 moveto
w 0 rlineto
0 h rlineto
w neg 0 rlineto
0 h neg rlineto
closepath

end
} def

/centred-box {
2 dict begin

/h exch def
/w exch def

w -0.5 mul h -0.5 mul moveto
w 0 rlineto
0 h rlineto
w neg 0 rlineto
0 h neg rlineto
closepath

end
} def

%[llx lly urx ury]

/rectangle {
4 dict begin

aload pop
/ury exch def
/urx exch def
/lly exch def
/llx exch def

llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
llx lly lineto
closepath

end
} def

% llx lly urx ury 

/bbox {
4 dict begin

/ury exch def
/urx exch def
/lly exch def
/llx exch def

llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
llx lly lineto
closepath

end
} def

/square {
1 dict begin

/s exch def

0 0 moveto
s 0 rlineto
0 s rlineto
s neg 0 rlineto
0 s neg rlineto
closepath
end
} def



% - closing box.inc ------------------------

newpath
 150 150 box clip

20 10 translate

72 dup scale
0.01 setlinewidth

/P[
 [0 0] 
 [0.5 1.6] 
 [1 1.4]
 [1.5 0] 
 [0.5 0.9] 
 [0.9 0.6] 
 [0.8 0.2] 
] def

newpath
P 0 get aload pop moveto
0 -3 rmoveto
0 6 rlineto
stroke

newpath
P 3 get aload pop moveto
0 -3 rmoveto
0 6 rlineto
stroke

newpath
P 3 get aload pop moveto
P 0 get aload pop lineto
P 1 get aload pop lineto
P 2 get aload pop lineto
closepath
gsave
0.8 setgray
% fill
grestore
% stroke

0 1 P length 1 sub {
/i exch def
newpath
P i get aload pop 0.032 0 360 arc
fill
} for



