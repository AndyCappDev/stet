%%BeginDocument: images9/logo9.eps
%!PS-Adobe-2.0
%%BoundingBox: 0 0 100 100

% - Inserting logo.inc ----------------------

%!

[ 0 0 100 100 ]

% - Inserting bbox.inc ----------------------

% [llx lly urx ury] on loading

% defines global variables llx urx lly ury width height

aload pop
/ury exch def
/urx exch def
/lly exch def
/llx exch def
/width urx llx sub def
/height ury lly sub def

% llx lly urx ury 

/box { 4 dict begin
/ury exch def
/urx exch def
/lly exch def
/llx exch def
llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
closepath
end } def

/boundary {
llx lly urx ury box
} def

/center {
llx lly translate
width 2 div height 2 div translate
} def

% - closing bbox.inc ------------------------


% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

% logo.inc

/h height 2 sub def
/w h 8.5 mul 11 div def
% page dimensions in points

width 0 translate
w neg 0 translate
-0.5 0.5 translate

/S 98 11 div def
S dup scale
1 S div setlinewidth

/page-boundary {
newpath
0 0 moveto
8.5 0 lineto
0 11 rlineto
0 11 lineto
closepath
} def





% - closing colours.inc ------------------------


% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

gsave
newpath
page-boundary 
clip

gsave
-0.6 0.8 translate
1 dict begin
1 36 div dup scale
/showpage{} def

% - Inserting tree-bis.eps ----------------------

%!PS-Adobe-2.0
%%BoundingBox: 0 0 332 332


% - Inserting colours.inc ----------------------

%!
% - closing colours.inc ------------------------
166 166 translate

/EDGES [ 0.7 0 0.0 ] def
/NODES [ 0.5 0.5 0.5 ] def

% global variables: edge length EL, line width LW, node radius R, factor F
% arguments:
% angle A + depth to go + factor f + location: x y
/draw { 
  16 dict begin
  /y exch def
  /x exch def
  /f exch def
  /d exch def
  /A exch def

  /B A 120 add 360 mod def
  /C B 120 add 360 mod def
  /el EL f mul def
  /r R f mul def
  LW f mul setlinewidth
  x y r
  % draw edges out, recurse; then node
  d 0 gt {
    EDGES aload pop setrgbcolor
    newpath
    x y moveto
      B cos el mul 
      B sin el mul
    rlineto

    x y moveto
      C cos el mul 
      C sin el mul
    rlineto
    stroke

    % put next 10 arguments on the stack
    B 180 add d 1 sub f F mul 
      x B cos el mul add
      y B sin el mul add
    C 180 add d 1 sub f F mul
      x C cos el mul add
      y C sin el mul add
    % remove the local dictionary 
    % before the recursive call
    % but after using the variables
    end
    draw
    draw
  }{
    end
  } ifelse
  NODES aload pop setrgbcolor
  newpath 0 360 arc 
  gsave
  1 setgray
  fill
  grestore
  currentlinewidth F div setlinewidth
  stroke
} def

/EL 1 def
/LW 1 10 div def
/R 0.1 def
/F 0.61 def
/D 6 def

72 dup scale
LW setlinewidth 

/draw-tree {
newpath
EDGES aload pop setrgbcolor
0 0 moveto
EL 0 lineto
0 0 moveto
120 cos EL mul 120 sin EL mul lineto
0 0 moveto
240 cos EL mul 240 sin EL mul lineto
stroke

newpath
NODES aload pop setrgbcolor
0 0 R 0 360 arc
gsave
1 setgray
fill
grestore
stroke

180 D F 
  EL 
  0 
draw
300 D F 
  120 cos EL mul 
  120 sin EL mul 
draw
60 D F 
  240 cos EL mul 
  240 sin EL mul
draw
} def

draw-tree

showpage


% - closing tree-bis.eps ------------------------
end
grestore

grestore

gsave
currentlinewidth 1 mul setlinewidth
0.6 setgray
newpath
page-boundary 
stroke
grestore



