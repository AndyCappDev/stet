%!PS
% PaintType 2 (Stroked Font) Test

% Create stroked version of Helvetica
/Helvetica findfont dup length 3 add dict copy begin
  /PaintType 2 def
  /StrokeWidth 40 def
  /FontName /Helvetica-Outline def
  currentdict end
/Helvetica-Outline exch definefont pop

% Row 1: Normal filled font
72 700 moveto
/Helvetica findfont 48 scalefont setfont
(Filled ABC 123) show

% Row 2: Stroked (outline) font
72 640 moveto
/Helvetica-Outline findfont 48 scalefont setfont
(Stroked ABC 123) show

% Row 3: Stroked with different StrokeWidth
/Helvetica findfont dup length 3 add dict copy begin
  /PaintType 2 def
  /StrokeWidth 80 def
  /FontName /Helvetica-ThickOutline def
  currentdict end
/Helvetica-ThickOutline exch definefont pop
72 580 moveto
/Helvetica-ThickOutline findfont 48 scalefont setfont
(Thick ABC 123) show

% Row 4: Stroked with color
72 520 moveto
1 0 0 setrgbcolor
/Helvetica-Outline findfont 48 scalefont setfont
(Red Outline) show

% Row 5: Side-by-side comparison at smaller size
0 0 0 setrgbcolor
72 460 moveto
/Helvetica findfont 24 scalefont setfont
(Normal) show
200 460 moveto
/Helvetica-Outline findfont 24 scalefont setfont
(Outline) show

% Row 6: NimbusRoman (Type 1 .t1 font) stroked
/NimbusRoman-Regular findfont dup length 3 add dict copy begin
  /PaintType 2 def
  /StrokeWidth 30 def
  /FontName /NimbusRoman-Outline def
  currentdict end
/NimbusRoman-Outline exch definefont pop
72 400 moveto
/NimbusRoman-Outline findfont 48 scalefont setfont
(Serif Outline) show

showpage
