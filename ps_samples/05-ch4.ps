%%BeginDocument: images4/map1.eps
%!PS-Adobe-2.0
%%BoundingBox: 0 0 360 200


% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

% - Inserting box.inc ----------------------

% box.inc

/box {
2 dict begin

/h exch def
/w exch def

0 0 moveto
w 0 rlineto
0 h rlineto
w neg 0 rlineto
0 h neg rlineto
closepath

end
} def

/centred-box {
2 dict begin

/h exch def
/w exch def

w -0.5 mul h -0.5 mul moveto
w 0 rlineto
0 h rlineto
w neg 0 rlineto
0 h neg rlineto
closepath

end
} def

%[llx lly urx ury]

/rectangle {
4 dict begin

aload pop
/ury exch def
/urx exch def
/lly exch def
/llx exch def

llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
llx lly lineto
closepath

end
} def

% llx lly urx ury 

/bbox {
4 dict begin

/ury exch def
/urx exch def
/lly exch def
/llx exch def

llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
llx lly lineto
closepath

end
} def

/square {
1 dict begin

/s exch def

0 0 moveto
s 0 rlineto
0 s rlineto
s neg 0 rlineto
0 s neg rlineto
closepath
end
} def



% - closing box.inc ------------------------
360 200 box 
clip

120 100 translate

72 dup scale
0.012 setlinewidth

/page {
newpath
-4.25 -5.5 moveto
8.5 0 rlineto
0 11 rlineto
-8.5 0 rlineto
closepath
stroke
} def

/N 8 def
/M N 1 sub def

/grid {
newpath
M neg 1 M {
/i exch def
i  N neg moveto
i  N lineto
} for

M neg 1 M {
/i exch def
N neg i moveto
 N i lineto
} for
stroke

0 setgray
newpath
N neg 0 moveto
 N 0 lineto
0 N neg moveto
0  N lineto
stroke
} def

% - user coordinates -------------------------------

/A matrix identmatrix def
/T 1.75 def
/s 0.16 def

% - page coordinates -------------------------------

gsave
T 0 translate
s s scale
currentlinewidth s div setlinewidth

gsave
A concat

0.8 setgray
grid

grestore
1 0 0 setrgbcolor
page

grestore

% -----------------------------------------------

/Courier-Bold findfont
0.13 scalefont
setfont

gsave
-1.5 0 translate

0 0 moveto (72 72 scale) show

0 0 moveto 
0 -0.16 rmoveto (4.25 5.5 translate) show

grestore

%%EndDocument
