%%BeginDocument: images8/c1.eps
%!PS-Adobe-2.0
%%BoundingBox: 0 0 180 80

/w 180 def

% set graphics environment
w 2 div 5 translate
/S 72 def
S dup scale
1 S div 2 div setlinewidth

% Draw the grid ...
/N 10 def
/dT 90 N div def
/R 1 def
/dr R N div def 
/T 0 def
/r 0 def

gsave
newpath
N 1 add {
0 0 moveto
T cos R mul T sin R mul lineto
/T T dT add def
} repeat
N 1 add {
r 0 moveto
0 0 r 0 90 arc
/r r dr add def
} repeat
stroke
grestore

