% - closing sphere.inc ------------------------


% - Inserting bernstein.inc ----------------------

%!

% t y=[ y0 y1 ... yn ]
/bernstein { % t y 
  % constants y n t s=1-t
  % variables k C P
  dup length % t y n+1
  1 sub      % t y n
  3 -1 roll 1 % y n t 1
  1 index sub % y n t s
  % constants in place
  1           % y n t s k
  3 index 3 index mul % y n t s k C=nt
  5 index 0 get       % y n t s k C P=y0
  5 index {           % y n t s k C P
    % P -> s.P + C.y[k]
    % C -> C.t.(n-k)/(k+1) 
    % k -> k+1
    3 index mul       % y n t s k C P.s
    1 index           % y n t s k C P.s C
    7 index           % y n t s k C P.s C y 
    4 index get mul add  % y n t s k C P.s+C.y[k]=new P
    3 1 roll          % y n t s P* k C
    5 index           % y n t s P* k C n
    2 index sub mul   % y n t s P* k C.(n-k)
    1 index 1 add div % y n t s P* k C.(n-k)/(k+1)
    4 index mul       % y n t s P* k C*
    3 1 roll 1 add    % y n t s C* P* k*
    3 1 roll          % y n t s k* C* P*
  } repeat
  7 1 roll 6 { pop } repeat
} def


% - closing bernstein.inc ------------------------


1 setlinecap
1 setlinejoin


% - Inserting harriot.inc ----------------------

%!

% --------------------------------

/page-begin {
  gsave
  llx urx add 2 div
  lly ury add 2 div 
  translate
  /S 100 def
  S dup scale
  1 S div setlinewidth
  -0.57 -0.2 translate
  1 setlinecap
  1 setlinejoin
} def

/page-end {
  grestore
} def

% ===========================================

/s-projection { 1 dict begin
  aload pop 
  /z exch def
  /y exch def
  /x exch def
  /t z dup 1 add div def
  /s 1 t sub def
  [ x s mul y s mul 0 ] 
end } def

% -------------------------------------------

/x 0.72 def
/y 0 def
/z 1 x dup mul y dup mul add sub sqrt def
/P [ x y z ] def
/dr 0.6 def
/dx [ z dr neg mul 0 x dr mul ] def

/an 37 def

/xQ x dx 0 get an cos mul add def
/yQ y dx 1 get an cos mul add def
/zQ z dx 2 get an cos mul add def

% Q = [ xQ yQ zQ ]
/Q [ xQ yQ zQ ] def

% dx = Q-P

/dy [ x y z ] dx cross-product -1 vector-scale def

% dy has same length as dx, perp. to it
% dx, dy = frame at P
/dQ dy an sin vector-scale def

% dQ = R-Q
/R [
    xQ dQ 0 get add 
    yQ dQ 1 get add 
    zQ dQ 2 get add 
] def

/P' P s-projection def
/Q' Q s-projection def
/R' R s-projection def

/dx' [ 
  Q' 0 get P' 0 get sub
  Q' 1 get P' 1 get sub
  Q' 2 get P' 2 get sub
] def

/dy' [ 0 0 1 ] dx' cross-product -1 vector-scale def

% P''' at z=zQ, equal to (1-t)(0 0 -1) + tP
% so t-1+tz = zQ, t(1+z)= 1+zQ
/t 1 zQ add 1 z add div def
/P''' [t x mul t y mul zQ] def

% --- PQR = the original triangle, P'Q'R' its projection  ----



% - closing harriot.inc ------------------------


[0 0 3 1] set-eye
[1 0 0 ] -53 rotate3d
[0 0 1 ] -43 rotate3d
/light-source [-0.5 1 2 0] normalized def

% ===========================================

currentlinewidth 4 div setlinewidth

page-begin

/E get-eye cim3d transform3d def
/L light-source cim3d transform3d def

16 [1 0.8 dup ] [ 0.3 dup dup dup dup 1 ] L 1 draw-sphere 

% ===========================================

gsave
/N 100 def
/A 0 def
/dA 360 N div def
0.3 setgray
newpath
0 0 -1 moveto3d
P' aload pop lineto3d
0 0 -1 moveto3d
Q' aload pop lineto3d
0 0 -1 moveto3d
R' aload pop lineto3d
stroke
grestore

gsave
newpath
currentlinewidth 1.5 mul setlinewidth
1 0 0 moveto3d
N {
  /A A dA add def
  A cos A sin 0 lineto3d
} repeat
gsave
1 0.9 dup setrgbcolor
% fill
grestore
1 0.9 dup setrgbcolor
stroke
grestore

gsave
0.3 setgray
newpath
P aload pop moveto3d
P' aload pop lineto3d
Q aload pop moveto3d
Q' aload pop lineto3d
R aload pop moveto3d
R' aload pop lineto3d
stroke
grestore

% --- the angle high ---------------------------------------

gsave
/N 16 def
/dt an N div def
/t 0 def
% f = ratio of dR to dr
/f 0.4 def
newpath
% circle on P + f.dx.cos t + f.dy.sin t
P aload pop moveto3d
N 1 add {
    P 0 get 
    dx 0 get f mul t cos mul add 
    dy 0 get f mul t sin mul add
    P 1 get 
    dx 1 get f mul t cos mul add 
    dy 1 get f mul t sin mul add 
    P 2 get 
    dx 2 get f mul t cos mul add 
    dy 2 get f mul t sin mul add 
  lineto3d
  /t t dt add def
} repeat 
closepath3d
gsave
1 0 0 setrgbcolor
fill
grestore
stroke
grestore

gsave
/N 16 def
/dt an N div def
/t 0 def
/f 0.56 def
newpath
% circle on P + f.dx.cos t + f.dy.sin t
P' aload pop moveto3d
N 1 add {
    P' 0 get 
    dx' 0 get f mul t cos mul add 
    dy' 0 get f mul t sin mul add
    P' 1 get 
    dx' 1 get f mul t cos mul add 
    dy' 1 get f mul t sin mul add 
    P' 2 get 
    dx' 2 get f mul t cos mul add 
    dy' 2 get f mul t sin mul add 
  lineto3d
  /t t dt add def
} repeat 
closepath3d
gsave
1 0 0 setrgbcolor
fill
grestore
stroke
grestore

% --- the rays ---------------------------------------------

gsave
currentlinewidth 1.2 mul setlinewidth
0 0 dup setrgbcolor
newpath
P aload pop moveto3d
Q aload pop lineto3d
R aload pop lineto3d
closepath
stroke
newpath
P' aload pop moveto3d
Q' aload pop lineto3d
R' aload pop lineto3d
closepath
stroke
grestore

page-end

% ---------------------------

2 0 translate

gsave
158 157 translate

