[ 8 6]
[ 8 7]
[ 7 1]
[ 6 1]
[ 5 1]
[ 4 1]
[ 3 1]
[ 2 1]
] def

% Draw the grid ...

/N 10 def
/llx 0.5 def
/lly 0 def
/urx 1.5 def
/ury 1 def
/dx urx llx sub N div def
/dy ury lly sub N div def

gsave
0.7 0 0 setrgbcolor
