% - Inserting bbox.inc ----------------------

% [llx lly urx ury] on loading

% defines global variables llx urx lly ury width height

aload pop
/ury exch def
/urx exch def
/lly exch def
/llx exch def
/width urx llx sub def
/height ury lly sub def

% llx lly urx ury 

/box { 4 dict begin
/ury exch def
/urx exch def
/lly exch def
/llx exch def
llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
closepath
end } def

/boundary {
llx lly urx ury box
} def

/center {
llx lly translate
width 2 div height 2 div translate
} def

% - closing bbox.inc ------------------------

newpath
boundary
clip

width 2 div height 2 div translate

/S 48 def
S dup scale
1 S div setlinewidth
-1 -0.1 translate

/A 53 def

/B 90 A sub 2 div def
/x B cos B sin div def

newpath
0 -1 moveto
x 0 rlineto
A cos A sin lineto
gsave
0.9 setgray
fill
grestore
stroke

/r 0.6 def
newpath
A cos A sin moveto
A sin neg r mul A cos r mul rlineto
r 0 rlineto
A cos A sin lineto
closepath
gsave
