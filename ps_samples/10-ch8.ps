% pars [x y]
/fcn { 8 dict begin
aload pop
/y exch def
/x exch def
/pars exch def
[[x dup mul y dup mul sub 2 x mul y mul][2 x mul -2 y mul 2 y mul 2 x mul]]
end } def

/nodes [
