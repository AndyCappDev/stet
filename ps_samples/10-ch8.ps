% - Inserting bbox.inc ----------------------

% [llx lly urx ury] on loading

% defines global variables llx urx lly ury width height

aload pop
/ury exch def
/urx exch def
/lly exch def
/llx exch def
/width urx llx sub def
/height ury lly sub def

% llx lly urx ury 

/box { 4 dict begin
/ury exch def
/urx exch def
/lly exch def
/llx exch def
llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
closepath
end } def

/boundary {
llx lly urx ury box
} def

/center {
llx lly translate
width 2 div height 2 div translate
} def

% - closing bbox.inc ------------------------

newpath
boundary clip


% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
