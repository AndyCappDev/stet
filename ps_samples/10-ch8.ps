%%BeginDocument: images8/rectangle-diagram.eps
%!PS-Adobe-2.0
%%BoundingBox: 0 0 100 160

% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

50 80 translate

/S 44 def
S dup scale
1 S div setlinewidth
/Pi 3.1415926536 def

gsave
0.7 setgray
-90 10 90 { /i exch def
i cos i sin moveto
i cos neg i sin lineto
} for
stroke
grestore

/N 9 def
/x 0 def
/dx //Pi 2 div N div def
/M 16 def

gsave
0.7 setgray
newpath
N {
  /x dx x add def
  /t 0 def
  /dt x M div def
  /X x t sub 180 mul //Pi div def
  X cos X sin moveto
  M {
    /t t dt add def
    /X x t sub 180 mul //Pi div def
    X cos X sin t add lineto
  } repeat
} repeat
stroke
grestore

/x 0 def
/dx //Pi -2 div N div def

gsave
0.7 setgray
newpath
N {
  /x dx x add def
  /t 0 def
  /dt x M div def
  /X x t sub 180 mul //Pi div def
  X cos X sin moveto
  M {
    /t t dt add def
    /X x t sub 180 mul //Pi div def
    X cos X sin t add lineto
  } repeat
} repeat
stroke
grestore

gsave
currentlinewidth 1.25 mul setlinewidth
newpath
0 0 1 0 360 
arc stroke
grestore

newpath
currentlinewidth 1.25 mul setlinewidth
1 0 moveto
0 1 //Pi -2 div mul rmoveto
0 1 //Pi mul rlineto
stroke

%%EndDocument
 @endspecial 150 5149 a @beginspecial 0 @llx 0 @lly 400
@urx 200 @ury 4320 @rwi @setspecial
%%BeginDocument: images8/rectangle.eps
%!PS-Adobe-2.0
%%BoundingBox: 0 0 400 200

% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ /Black /Spot ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

/setrgbcolor {
  Duotone setcolorspace
  pop 
  1 2 index
  sub 
  3 1 roll 
  sub
  setcolor
} def
% - closing colours.inc ------------------------

200 100 translate


% - Inserting world.inc ----------------------


/MAX 89.5 def
/DMAX MAX 2 mul 18 div def

% ======================================================

/coasts
[

