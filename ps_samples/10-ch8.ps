% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ /Black /Spot ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

/setrgbcolor {
  Duotone setcolorspace
  pop 
  1 2 index
  sub 
  3 1 roll 
  sub
  setcolor
} def
% - closing colours.inc ------------------------
