exch					% x y x1 y1 y dy/dx x
h 0.3333 mul sub		% x y x1 y1 y dy/dx x2
3 1 roll				% x y x1 y1 x2 y dy/dx 
0.3333 mul h mul sub	% x y x1 y1 x2 y2

2 copy 0.6 pixel
% print

6 4 roll

2 copy 0 pixel
% print

curveto
} repeat
stroke
} def

