3 1 roll				% x1 y dy/dx
0.3333 mul h mul add	% x1 y1 = y + (h/3)(dy/dx)

2 copy 0.6 pixel
% print

currentpoint			% x1 y1 x y
pop h add				% x1 y1 newx
dup f 					% x1 y1 x y
2 copy					% x1 y1 x y x y
6 2 roll				% x y x1 y1 x y 
