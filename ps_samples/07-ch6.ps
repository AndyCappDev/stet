%%BoundingBox: 0 0 260 100


% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------


% - Inserting box.inc ----------------------

% box.inc

/box {
2 dict begin

/h exch def
/w exch def

0 0 moveto
w 0 rlineto
0 h rlineto
w neg 0 rlineto
0 h neg rlineto
closepath

end
} def

/centred-box {
2 dict begin

/h exch def
/w exch def

w -0.5 mul h -0.5 mul moveto
w 0 rlineto
0 h rlineto
w neg 0 rlineto
0 h neg rlineto
closepath

end
} def

%[llx lly urx ury]

/rectangle {
4 dict begin

aload pop
/ury exch def
/urx exch def
/lly exch def
/llx exch def

llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
llx lly lineto
closepath

end
} def

% llx lly urx ury 

/bbox {
4 dict begin

/ury exch def
/urx exch def
/lly exch def
/llx exch def

llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
llx lly lineto
closepath

end
} def

/square {
1 dict begin

/s exch def

0 0 moveto
s 0 rlineto
0 s rlineto
s neg 0 rlineto
0 s neg rlineto
closepath
end
} def



% - closing box.inc ------------------------
% newpath 260 100 box stroke

20 10 translate


% - Inserting bezier.inc ----------------------

% set 
%	pixwd 
% and 
%	linewidth
% for control lines

/pwd 0.025 def

% x y on stack

/whitepixel {
gsave
translate
1 setgray
newpath
pwd neg pwd neg moveto
pwd pwd neg lineto
pwd pwd lineto
pwd neg pwd lineto
closepath
fill
0 setgray
newpath
pwd neg pwd neg moveto
pwd pwd neg lineto
pwd pwd lineto
pwd neg pwd lineto
closepath
stroke
grestore
} def

/blackpixel {
gsave
translate
newpath
pwd neg pwd neg moveto
pwd pwd neg lineto
pwd pwd lineto
pwd neg pwd lineto
closepath
fill
grestore
0 setgray
stroke
} def

% [x0 y0] [x1 y1] [x2 y2] [x3 y3]  

/controlcurve {
8 dict begin
/P3 exch def
/P2 exch def
/P1 exch def
/P0 exch def

gsave
controlwidth setlinewidth
0.8 setgray
newpath
P0 aload pop moveto
P1 aload pop lineto
P3 aload pop moveto
P2 aload pop lineto
stroke
grestore

P0 aload pop moveto
P1 aload pop
P2 aload pop
P3 aload pop
curveto

P0 aload pop blackpixel
P1 aload pop whitepixel
P2 aload pop whitepixel
P3 aload pop blackpixel

stroke
end
} def


% - closing bezier.inc ------------------------

72 72 scale
0.012 setlinewidth

/pwd 0.025 def
/controlwidth 0.020 def

% x y on stack

[0 0]
[1 1]
[2 1]
[3 0]
controlcurve


