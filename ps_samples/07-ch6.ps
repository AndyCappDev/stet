%%BeginDocument: images6/cornu.eps
%!PS-Adobe-2.0
%%BoundingBox: 0 0 200 200
[0 0 200 200]

% - Inserting bbox.inc ----------------------

% [llx lly urx ury] on loading

% defines global variables llx urx lly ury width height

aload pop
/ury exch def
/urx exch def
/lly exch def
/llx exch def
/width urx llx sub def
/height ury lly sub def

% llx lly urx ury 

/box { 4 dict begin
/ury exch def
/urx exch def
/lly exch def
/llx exch def
llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
closepath
end } def

/boundary {
llx lly urx ury box
} def

/center {
llx lly translate
width 2 div height 2 div translate
} def

% - closing bbox.inc ------------------------


% - Inserting display.inc ----------------------

/display { 1 dict begin
  /n exch def
  n copy [ n 1 add 1 roll ] ==
end } def
% - closing display.inc ------------------------

center

/S 96 def
S dup scale

% plotting a path integral F(T) = \int_{0}^{T} f(t) dt
% A perfect setup for Bezier, since F' = f is given in advance
% DF =  [ f(t) + 4 f(t+dt/2) + f(t+dt)] [ dt / 6 ]

/f { 1 dict begin
/x exch dup mul 180 mul 3.14159326526 div def
[ 
  x cos x sin neg 
]
end } def

2 { 

1 S div setlinewidth

/t 0 def
/dt 0.1 def
/X 0 def
/Y 0 def
/N 80 def
/q 0.96 def

% X Y = position, x y = speed
/X 0 def
/Y 0 def
t f aload pop
/y exch def
/x exch def

newpath
N {
  newpath
  X Y moveto
  X 
    x dt mul 3 div 
  add
  Y
    y dt mul 3 div
  add
  % X1 Y1
  t dt 0.5 mul add f aload pop
  /y1 exch def
  /x1 exch def
  /t t dt add def
  t f aload pop
  /y2 exch def
  /x2 exch def
  /X X 
    x x1 4 mul add x2 add dt mul 6 div 
  add def
  /Y Y 
    y y1 4 mul add y2 add dt mul 6 div 
  add def
  /y y2 def
  /x x2 def
  X 
    x dt mul 3 div 
  sub
  Y
    y dt mul 3 div
  sub
  X Y curveto
  stroke
  currentlinewidth q mul setlinewidth
} repeat
stroke

180 rotate

} repeat



