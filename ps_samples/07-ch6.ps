%!PS-Adobe-2.0
%%BoundingBox: 0 0 80 80


% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

/path-to-array {
	[
  		{ [ 0 4 2 roll ] } 
  		{ [ 1 4 2 roll ] } 
  		{ [ 2 8 2 roll ] } 
  		{ [ 3 ] } 
		pathforall
	]
} def
	
/path-display {
  { (moveto) == [ 3 1 roll ] == } 
  { (lineto) == [ 3 1 roll ] ==  } 
  { (curveto) == [ 7 1 roll ] == } 
  { (closepath) == } 
  pathforall
} def

/Times-Roman findfont
1 scalefont
setfont

0 4 translate 

100 dup scale
1 100 div setlinewidth

newpath
0 0 moveto
(O) true charpath
/P 
path-to-array 
def
gsave
1 0.7 0.7 setrgbcolor
fill
grestore
stroke

