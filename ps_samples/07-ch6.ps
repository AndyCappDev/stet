%%BeginDocument: images6/quadratic2.eps
%!PS-Adobe-2.0
%%BoundingBox: 0 0 108 108


% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

/pi 3.1415926536 def


% - Inserting display.inc ----------------------

/display { 1 dict begin
  /n exch def
  n copy [ n 1 add 1 roll ] ==
end } def
% - closing display.inc ------------------------
gsave

54 54 translate

/S 48 def
S dup scale
1 S div setlinewidth


% - Inserting quadto.inc ----------------------

%!

% x1 y1 x2 y2 -> X1 Y1 X2Y2 X3 Y3 curveto
/quadto { 1 dict begin
  currentpoint                                        % x1 y1 x2 y2 x0 y0 
  4 index dup add add 3 div                    % x1 y1 x2 y2 x0 (y0+2 y1)/3
  6 1 roll                                                % Y1 x1 y1 x2 y2 x0 
  4 index dup add add 3 div                    % Y1 x1 y1 x2 y2 (x0+2 x1)/3
  6 1 roll                                                % X1 Y1 x1 y1 x2 y2 
  2 copy                                                % X1 Y1 x1 y1 x2 y2 x2 y2
  5 -1 roll dup add add 3 div                    % X1 Y1 x1 x2 y2 x2 (y2 + 2 y1)/3
  5 1 roll                                                % X1 Y1 Y2 x1 x2 y2 x2 
  4 -1 roll dup add add 3 div                    % X1 Y1 Y2 x2 y2 X2
  4 1 roll                                                % X1 Y1 X2 Y2 x2 y2
  curveto
end } def


% - closing quadto.inc ------------------------

% - Inserting line-intersection.inc ----------------------

%!

% [a b c] [A B C]
/line-intersection { 1 dict begin

aload pop
/C exch def
/B exch def
/A exch def
aload pop
/c exch def
/b exch def
/a exch def

% Ax + By + C = 0
% ax + by + c = 0
% [x y] = [-C -c] M^{-1}
/det B a mul  A b mul sub def % really -det
b C mul B c mul sub det div
c A mul C a mul sub det div

end } def

% - closing line-intersection.inc ------------------------
% t -> (x, y) with x^2 + y^2 = 1
/f { 1 dict begin
//pi div 180 mul
dup cos 
/x exch def
sin 
/y exch def
[x y]
[ x y -1 ] 
} def

% -----------------------------------

gsave
0.7 setgray
currentlinewidth 1 mul setlinewidth
newpath
0 0 1 0 360 arc 
stroke
grestore

/t 0 def
/N 4 def
/dt 2 //pi mul N div def

gsave
0.7 0 0 setrgbcolor
newpath
t f 
/fP exch def
/P exch def
P aload pop moveto
N {
  /t t dt add def
  t f /fQ exch def
  /Q exch def
  fP fQ line-intersection 
  Q aload pop quadto
  /fP fQ def
} repeat
stroke
grestore



