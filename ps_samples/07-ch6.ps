%%BeginDocument: images6/decasteljau2.eps
%!PS-Adobe-2.0
%%BoundingBox: 0 0 180 98


% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

92 6 translate

72 72 scale
1 72 div setlinewidth
1.00 1.00 scale

/pwd 0.016 def

% x y on stack

% g x y

/pixel {
gsave
translate
setgray
newpath
pwd neg pwd neg moveto
pwd pwd neg lineto
pwd pwd lineto
pwd neg pwd lineto
closepath
fill
0 setgray
newpath
pwd neg pwd neg moveto
pwd pwd neg lineto
pwd pwd lineto
pwd neg pwd lineto
closepath
stroke
grestore
} def

% x1 y1 x2 y2 

/controlcurve {
/y2 exch def
/x2 exch def
/y1 exch def
/x1 exch def

gsave

0.7 setgray
newpath
-1 0 moveto
x1 y1 lineto
x2 y2 lineto
1 0 lineto
stroke

grestore

-1 0 
moveto
x1 y1
x2 y2 
1 0
curveto
stroke

} def

/decasteljau {
/y2 exch def
/x2 exch def
/y1 exch def
/x1 exch def

newpath 

0 -1 0 pixel
1 1 0 pixel

1 x1 y1 pixel
1 x2 y2 pixel

-1 x1 add 2 div
/p1 exch def
0 y1 add 2 div
/q1 exch def

1 x2 add 2 div
/p3 exch def 
0 y2 add 2 div 
/q3 exch def

x1 x2 add 2 div 
/p2 exch def
y1 y2 add 2 div 
/q2 exch def

p1 p2 add 2 div 
/p12 exch def
q1 q2 add 2 div
/q12 exch def

p3 p2 add 2 div 
/p23 exch def
q3 q2 add 2 div
/q23 exch def

p12 p23 add 2 div
/p13 exch def
q12 q23 add 2 div
/q13 exch def

0.7 setgray
newpath
p1 q1 moveto
p2 q2 lineto
p3 q3 lineto
p12 q12 moveto
p23 q23 lineto
stroke

0 setgray

0 p1 q1 pixel
1 p2 q2 pixel
1 p3 q3 pixel
0 p12 q12 pixel
1 p23 q23 pixel
0 p13 q13 pixel

} def


-0.9 1
0.4 1
controlcurve

-0.9 1
0.4 1
decasteljau


