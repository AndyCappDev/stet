% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
