% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

gsave

10 5 translate


% - Inserting quadto.inc ----------------------

%!

% x1 y1 x2 y2 -> X1 Y1 X2Y2 X3 Y3 curveto
/quadto { 1 dict begin
  currentpoint                                        % x1 y1 x2 y2 x0 y0 
  4 index dup add add 3 div                    % x1 y1 x2 y2 x0 (y0+2 y1)/3
  6 1 roll                                                % Y1 x1 y1 x2 y2 x0 
  4 index dup add add 3 div                    % Y1 x1 y1 x2 y2 (x0+2 x1)/3
  6 1 roll                                                % X1 Y1 x1 y1 x2 y2 
  2 copy                                                % X1 Y1 x1 y1 x2 y2 x2 y2
  5 -1 roll dup add add 3 div                    % X1 Y1 x1 x2 y2 x2 (y2 + 2 y1)/3
  5 1 roll                                                % X1 Y1 Y2 x1 x2 y2 x2 
  4 -1 roll dup add add 3 div                    % X1 Y1 Y2 x2 y2 X2
  4 1 roll                                                % X1 Y1 X2 Y2 x2 y2
  curveto
end } def


% - closing quadto.inc ------------------------

/dx 2 def
/dy dx def

/mkpixel {
  1 dict begin
  /y exch def
  /x exch def
  newpath
  x y moveto
  dx neg dy neg rmoveto
  dx 2 mul 0 rlineto
  0 dy 2 mul rlineto
  dx -2 mul 0 rlineto
  closepath
    gsave
  0.6 setgray
  fill
    grestore
  stroke
  end
} def

/P [
[0 0]
[60 75]
[137 47]
] def

gsave
currentlinewidth 2 mul setlinewidth
0.7 setgray
newpath
P 0 get aload pop moveto
P 1 get aload pop lineto
P 2 get aload pop lineto
stroke
grestore

newpath
P 0 get aload pop moveto
P 1 get aload pop 
P 2 get aload pop quadto
stroke

P 0 get aload pop mkpixel
P 1 get aload pop mkpixel
P 2 get aload pop mkpixel

grestore


