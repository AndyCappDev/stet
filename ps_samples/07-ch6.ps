%%BoundingBox: 0 0 150 150

% - Inserting box.inc ----------------------

% box.inc

/box {
2 dict begin

/h exch def
/w exch def

0 0 moveto
w 0 rlineto
0 h rlineto
w neg 0 rlineto
0 h neg rlineto
closepath

end
} def

/centred-box {
2 dict begin

/h exch def
/w exch def

w -0.5 mul h -0.5 mul moveto
w 0 rlineto
0 h rlineto
w neg 0 rlineto
0 h neg rlineto
closepath

end
} def

%[llx lly urx ury]

/rectangle {
4 dict begin

aload pop
/ury exch def
/urx exch def
/lly exch def
/llx exch def

llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
llx lly lineto
closepath

end
} def

% llx lly urx ury 

/bbox {
4 dict begin

/ury exch def
/urx exch def
/lly exch def
/llx exch def

llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
llx lly lineto
closepath

end
} def

/square {
1 dict begin

/s exch def

0 0 moveto
s 0 rlineto
0 s rlineto
s neg 0 rlineto
0 s neg rlineto
closepath
end
} def



% - closing box.inc ------------------------


% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

newpath
% 150 150 box stroke

20 10 translate

72 dup scale
0.01 setlinewidth

/P0 [0 0] def
/P1 [1.5 0] def
/P2 [0.5 1.6] def

/c0 0.25 def
/c1 0.25 def
/c2 0.5 def


newpath
P0 aload pop moveto
P1 aload pop lineto
P2 aload pop lineto
closepath
gsave
0.8 setgray
fill
grestore
stroke

/N 10 def
/t 0 def
/dt 1 N div def
N {
newpath
P2 aload pop moveto
  P0 0 get 1 t sub mul P1 0 get t mul add
  P0 1 get 1 t sub mul P1 1 get t mul add
lineto
stroke
/t t dt add def
} repeat




newpath
P0 aload pop 0.032 0 360 arc
fill

newpath
P1 aload pop 0.032 0 360 arc
fill

newpath
P2 aload pop 0.032 0 360 arc
fill


