% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

newpath
% 150 150 box stroke

20 10 translate

72 dup scale
0.01 setlinewidth

/P[
 [0 0] 
 [0.5 1.6] 
 [1 1.4]
 [1.5 0] 
 [0.5 0.9] 
 [0.9 0.6] 
 [0.8 0.2] 
] def

newpath
P 3 get aload pop moveto
P 0 get aload pop lineto
P 1 get aload pop lineto
P 2 get aload pop lineto
closepath
gsave
0.8 setgray
fill
grestore
stroke

0 1 P length 1 sub {
/i exch def
newpath
P i get aload pop 0.032 0 360 arc
fill
} for



