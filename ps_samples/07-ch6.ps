%%BeginDocument: images6/logo6.eps
%!PS-Adobe-2.0
%%BoundingBox: 0 0 100 100

% - Inserting logo.inc ----------------------

%!

[ 0 0 100 100 ]

% - Inserting bbox.inc ----------------------

% [llx lly urx ury] on loading

% defines global variables llx urx lly ury width height

aload pop
/ury exch def
/urx exch def
/lly exch def
/llx exch def
/width urx llx sub def
/height ury lly sub def

% llx lly urx ury 

/box { 4 dict begin
/ury exch def
/urx exch def
/lly exch def
/llx exch def
llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
closepath
end } def

/boundary {
llx lly urx ury box
} def

/center {
llx lly translate
width 2 div height 2 div translate
} def

% - closing bbox.inc ------------------------


% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

% logo.inc

/h height 2 sub def
/w h 8.5 mul 11 div def
% page dimensions in points

width 0 translate
w neg 0 translate
-0.5 0.5 translate

/S 98 11 div def
S dup scale
1 S div setlinewidth

/page-boundary {
newpath
0 0 moveto
8.5 0 lineto
0 11 rlineto
0 11 lineto
closepath
} def





% - closing colours.inc ------------------------


% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

/dx 0.4 def

/pixel { 1 dict begin
/y exch def
/x exch def
x y moveto
dx -0.5 mul dup rmoveto
dx 0 rlineto
0 dx rlineto
dx neg 0 rlineto
closepath
end } def

gsave
newpath
page-boundary 
clip

/P [
[ 2 2]
[ 2 5 add 2 2 add ]
[2 0 add 5 2 add ]
[2 5 add 2 7 add ]
] def

newpath
P 0 get aload pop moveto
P 1 get aload pop
P 2 get aload pop 
P 3 get aload pop curveto
stroke

gsave
1 0.7 0.7 setrgbcolor
newpath
P 0 get aload pop moveto
P 1 get aload pop lineto
P 2 get aload pop moveto
P 3 get aload pop lineto
stroke
grestore

newpath
P 0 get aload pop pixel
gsave
0.7 0 0 setrgbcolor
fill
grestore
stroke

newpath
P 1 get aload pop pixel
gsave
0.7 0 0 setrgbcolor
fill
grestore
stroke

newpath
P 2 get aload pop pixel
gsave
0.7 0 0 setrgbcolor
fill
grestore
stroke

newpath
P 3 get aload pop pixel
gsave
0.7 0 0 setrgbcolor
fill
grestore
stroke

grestore

gsave
currentlinewidth 1 mul setlinewidth
0.6 setgray
newpath
page-boundary 
stroke
grestore



