% rotation matrix A 
/axis {
4 dict begin
/A exch def

[
  A 0 get 1 sub
  A 1 get
  A 2 get
]

[
  A 3 get
  A 4 get 1 sub
  A 5 get 
]

cross-product

end

} def


% - closing sphere.inc ------------------------

% latitudes in columns 
/sphere-vertex { 1 dict begin
/N exch def
/dA 360 N div 2 div def
/dB 180 N div def
[
/A 0 def
% A = longitude
2 N mul 1 add { 
  [
  /B -90 def
  % B = latitude
  N 1 add {
    [ 1 A B P aload pop ] 
    /B B dB add def
  } repeat
  ]
  /A A dA add def
} repeat
]
end } def

/N 24 def
/S N sphere-vertex def

/sphere [
0 1 2 N mul 1 sub { 
  /i exch def
  0 1 N 1 sub { /j exch def
	/P S i get j get def
	/Q S i 1 add get j get def
	/R S i 1 add get j 1 add get def
	/n [ [ P aload pop pop ] [ Q aload pop pop ] [ R aload pop pop] ] normal-function def
	n length 0 ne {
		[ P Q R n ] 
	} if
	/P S i get j get def
	/Q S i 1 add get j 1 add get def
	/R S i get j 1 add get def
	/n [ [ P aload pop pop ] [ Q aload pop pop ] [ R aload pop pop] ] normal-function def
	n length 0 ne {
		[ P Q R n ] 
	} if
  } for
} for
] def

/hemi-sphere [
0 1 2 N mul 1 sub { 
  /i exch def
  0 1 N 1 sub 2 div { /j exch def
	/P S i get j get def
	/Q S i 1 add get j get def
	/R S i 1 add get j 1 add get def
	/n [ [ P aload pop pop ] [ Q aload pop pop ] [ R aload pop pop] ] normal-function def
	n length 0 ne {
		[ P Q R n ] 
	} if
	/P S i get j get def
	/Q S i 1 add get j 1 add get def
	/R S i get j 1 add get def
	/n [ [ P aload pop pop ] [ Q aload pop pop ] [ R aload pop pop] ] normal-function def
	n length 0 ne {
		[ P Q R n ] 
	} if
  } for
} for
] def

