0.01 setlinewidth

/P [1 0 0] def
/Q [0.75 1 0] def

[0 0 8 1] set-eye

[1 0 0] -60 rotate3d
[0 0 1] -20 rotate3d

gsave
0.8 setgray
newpath
-0.25 0 0 moveto3d
 2.25 0 0 lineto3d
-0.25 1 0 moveto3d
 2.25 1 0 lineto3d
  0 -0.25 0 moveto3d
  0  1.25 0 lineto3d
  1 -0.25 0 moveto3d
  1  1.25 0 lineto3d
  2 -0.25 0 moveto3d
  2  1.25 0 lineto3d
  0 0  1.25 moveto3d
  0 0 -1.25 lineto3d
stroke
grestore

