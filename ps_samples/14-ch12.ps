/Q R2 R1 matrix-mul axis normalized def


/Arc1 A P spherical-arc def
/Arc2 P B spherical-arc def
/Arc3 B Q spherical-arc def
/Arc4 Q A spherical-arc def
/Arc5 A B spherical-arc def

gsave
currentlinewidth 4 mul setlinewidth
0 0 0 setrgbcolor
newpath
Arc1 0 get aload pop pop moveto3d
Arc1 {
  aload pop
  /normal exch def
  E normal dot-product 0 gt {
  	lineto3d
  }{
    moveto3d
  } ifelse
} forall
Arc2 {
  aload pop
  /normal exch def
  E normal dot-product 0 gt {
  	lineto3d
  }{
    moveto3d
  } ifelse
} forall
Arc3 {
  aload pop
  /normal exch def
  E normal dot-product 0 gt {
  	lineto3d
  }{
    moveto3d
  } ifelse
} forall
Arc4 {
  aload pop
  /normal exch def
  E normal dot-product 0 gt {
  	lineto3d
  }{
    moveto3d
  } ifelse
} forall
gsave
1 setgray
stroke
grestore

newpath
Arc5 0 get aload pop pop moveto3d
