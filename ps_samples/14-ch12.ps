Q 1 get Q 0 get atan /T exch def 
/r Q 1 get dup mul Q 0 get dup mul add sqrt def
[0 0 1] T rotate3d
newpath
r 0.032 plainarrow3d
gsave
1 0 0 setrgbcolor
fill
grestore
currentlinewidth 2 div setlinewidth
stroke
grestore3d

gsave3d
[0 1 0] -90 rotate3d
[1 0 0] -90 rotate3d
/r P 0 get Q 1 get mul def
newpath
r 0.032 plainarrow3d
gsave
1 0 0 setrgbcolor
fill
grestore
currentlinewidth 2 div setlinewidth
stroke
