%%BeginDocument: imagesp/trithemius-circle.eps
%!PS-Adobe-2.0
%%BoundingBox: 0 0 220 220

% - Inserting colours.inc ----------------------

%!
% - closing colours.inc ------------------------

gsave
110 110 translate
14 rotate

/B matrix currentmatrix def

1 dup scale
1 1 div setlinewidth


% - Inserting display.inc ----------------------

/display { 1 dict begin
  /n exch def
  n copy [ n 1 add 1 roll ] ==
end } def
% - closing display.inc ------------------------


% - Inserting transform.inc ----------------------

%!

% <int> set-sd: sets subdivision depth
% <procedure> set-transform: defines the trsnaform
% <PS matrix> set-base: sets coordinates for the transform to be applied in
% subdivide: subdivides the current path
% path-transform: applies transform to the current path to 

/transformdict 32 dict def

transformdict begin

/base matrix currentmatrix def
/ibase base matrix invertmatrix def

% subdivision depth
/sd 0 def

% arguments: x y
% default is the identity
/tf {
  % 2 display
} def

% argument: non-negative integer
/set-sd {
  /sd exch def
} def

% argument: the transform procedure itself
/set-transform { 
  /tf exch def
} def

/set-base { 
  /base exch def
  /ibase base matrix invertmatrix def
} def

% stroke, fill, clip, show are redfined

/xstroke {
  stroke
} bind def

/xfill {
  fill
} bind def

/xclip {
  clip
} bind def

/xcurrentpoint {
  currentpoint
} bind def

/stroke {
  sd { subdivide } repeat
  path-transform
  xstroke
} def

/fill {
  sd { subdivide } repeat
  path-transform
  xfill
} def

/clip {
  sd { subdivide } repeat
  path-transform
  xclip
} def

/show {
  true charpath 
  currentpoint 
  % x y on stack
  fill 
  newpath 
  moveto
} def

% replaces the current path by a subdivided path
% moveto, closepath: no difference
% line segments are turned to Bezier curves,
% Bezier curves are bisected

/subdivide { 16 dict begin
[
  { % x y (moveto)
	/cy exch def
	/cx exch def
	/lx cx def
	/ly cy def
    [ cx cy {moveto}]
  }
  { % x y (lineto)
	/Y exch def
	/X exch def
    [ 
		0.66667 cx mul 0.33333 X mul add 
		0.66667 cy mul 0.33333 Y mul add 
		0.33333 cx mul 0.66667 X mul add 
		0.33333 cy mul 0.66667 Y mul add 
		X Y 
		/cx X def
		/cy Y def
		{curveto}
	]
	/cx X def
	/cy Y def
  }
  { % x1 y1 x2 y2 x3 y3
	/y3 exch def /x3 exch def
	/y2 exch def /x2 exch def
	/y1 exch def /x1 exch def
	/x01 cx x1 add 0.5 mul def
	/y01 cy y1 add 0.5 mul def
	/x12 x1 x2 add 0.5 mul def
	/y12 y1 y2 add 0.5 mul def
	/x23 x2 x3 add 0.5 mul def
	/y23 y2 y3 add 0.5 mul def
	/x012 x01 x12 add 0.5 mul def
	/y012 y01 y12 add 0.5 mul def
	/x123 x12 x23 add 0.5 mul def
	/y123 y12 y23 add 0.5 mul def
	
	[ x01 y01
      x012 y012
	    x012 x123 add 0.5 mul
	    y012 y123 add 0.5 mul
      {curveto} 
	]
	[ x123 y123
	  x23 y23
	  x3 y3
      {curveto} 
	]
	/cx x3 def /cy y3 def
  }
  {
    [ {closepath} ]
	/cx lx def
	/cy ly def
  }
  pathforall
]
newpath
{
  aload pop exec
} forall
end } def

% The transformation tf always to be applied to base coords

/path-transform {
[
  {
    % x y in user coordinates
    transform ibase transform    % base coords
    tf base transform itransform % user coords
    [ 3 1 roll { moveto} ]
  }
  {
    transform ibase transform    % base coords
    tf base transform itransform % in user coords 
    [ 3 1 roll {lineto} ] 
  }
  {
    transform ibase transform    % base coords
    tf base transform itransform % user coords
    6 2 roll 
    transform ibase transform
    tf base transform itransform 6 2 roll 
    transform ibase transform
    tf base transform itransform 6 2 roll
    [ 7 1 roll {curveto}]
  }
  {
    [ {closepath} ]
  } 
  pathforall
]
  newpath
  {
    aload pop exec
  } forall
  
} def
end


% - closing transform.inc ------------------------

% bounding box of the imported file:
/llx 81 def
/lly 713 def
/urx 389 def
/ury 719 def

/boxwidth urx llx sub def
% the width of the box we are displaying
/height ury lly sub def
/A0 270 7 sub def
/A1 -90 7 add def
/radius 100 def
/factor A0 A1 sub 360 div def 
% proportion of a full circle we take up
/truelength factor 3.1416 mul 2 mul radius mul def
% the length it will take up on the circle

/f { 1 dict begin
  % 2 display 
  /y exch lly sub def
  /x exch llx sub def
  /T 1 x boxwidth div sub A0 A1 sub mul A0 add def
  /R 100 height 2 div sub y truelength boxwidth div mul add def
  T cos R mul T sin R mul
end } def

gsave

transformdict begin

/f load set-transform
B set-base

1 dict begin
/showpage{} def

