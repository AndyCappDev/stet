%%BeginDocument: images2/shear.eps
%! 

%%BoundingBox: 0 0 296 72


% - Inserting box.inc ----------------------

% box.inc

/box {
2 dict begin

/h exch def
/w exch def

0 0 moveto
w 0 rlineto
0 h rlineto
w neg 0 rlineto
0 h neg rlineto
closepath

end
} def

/centred-box {
2 dict begin

/h exch def
/w exch def

w -0.5 mul h -0.5 mul moveto
w 0 rlineto
0 h rlineto
w neg 0 rlineto
0 h neg rlineto
closepath

end
} def

%[llx lly urx ury]

/rectangle {
4 dict begin

aload pop
/ury exch def
/urx exch def
/lly exch def
/llx exch def

llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
llx lly lineto
closepath

end
} def

% llx lly urx ury 

/bbox {
4 dict begin

/ury exch def
/urx exch def
/lly exch def
/llx exch def

llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
llx lly lineto
closepath

end
} def

/square {
1 dict begin

/s exch def

0 0 moveto
s 0 rlineto
0 s rlineto
s neg 0 rlineto
0 s neg rlineto
closepath
end
} def



% - closing box.inc ------------------------
296 72 box 
clip

10 8 translate

72 72 scale
0.012 setlinewidth

1 setlinecap
1 setlinejoin


/b 1.3 def
/a 0.7 def

newpath
0 0 moveto
b 0 lineto
0 a rlineto
b neg 0 rlineto
0 0 lineto
closepath
stroke

2 0 translate

newpath
0 0 moveto
b 0 lineto
0.5 a rlineto
b neg 0 rlineto
0 0 lineto
closepath
stroke



