/interpolate {
4 dict begin
/t exch def
/v exch def
/u exch def
[
  u 0 get 1 t sub mul v 0 get t mul add
  u 1 get 1 t sub mul v 1 get t mul add
]
end
} def

0.8 setgray
newpath
x y c add moveto
x y sub x y add lineto
x y c add moveto
y x neg rlineto
stroke

