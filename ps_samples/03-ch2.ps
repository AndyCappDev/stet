%!PS-Adobe-2.0
%%BoundingBox: 0 0 86 84


% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

gsave

/w 86 def
/h 84 def

1 setlinecap
1 setlinejoin

20 5 translate

/S 72 def
S dup scale
1 S div setlinewidth


% - Inserting arrows.inc ----------------------


/cot { dup cos exch sin div } def

% arrowlength shaftwidth headwidth A B
% A B are angles at point, back of head 

/arrow {
12 dict begin
/B exch def
/A exch def
/headwidth exch def
/shaftwidth exch def
/w shaftwidth 0.5 mul def
/arrowlength exch def

/x headwidth 2 div A cot mul def
/y headwidth 2 div B cot mul def
/z shaftwidth 2 div B cot mul def

/shaftlength arrowlength x sub y add z sub def

currentlinecap 0 eq {
0 w neg moveto
0 w lineto
shaftlength w lineto
arrowlength x sub headwidth 0.5 mul lineto
arrowlength 0 lineto
arrowlength x sub headwidth -0.5 mul lineto
shaftlength w neg lineto
closepath
} if

currentlinecap 1 eq {
0 w neg moveto
0 0 w -90 90 arcn
shaftlength w lineto
arrowlength x sub headwidth 0.5 mul lineto
arrowlength 0 lineto
arrowlength x sub headwidth -0.5 mul lineto
shaftlength w neg lineto
closepath
} if

currentlinecap 2 eq {
w neg 0 moveto
w neg w lineto
shaftlength w lineto
arrowlength x sub headwidth 0.5 mul lineto
arrowlength 0 lineto
arrowlength x sub headwidth -0.5 mul lineto
shaftlength w neg lineto
w neg w neg lineto
closepath
} if

end
} def

% A = 24, B = 60 are good

% x y shaft-width head-width A B

/mkarrow {
12 dict begin
/B exch def
/A exch def
/headwidth exch def
/shaftwidth exch def
/y exch def
/x exch def
/C y x atan def
C rotate
/r x dup mul y dup mul add sqrt def
r shaftwidth headwidth A B arrow
C neg rotate
end } def

% draws along a Bezier curve
% P0 P1 P2 P3 sw hw A B

/fillcurvedarrow { 16 dict begin
gsave
/B exch def
/A exch def
/hw exch def
/sw exch def
/P3 exch def
/P2 exch def
/P1 exch def
/P0 exch def
newpath
sw setlinewidth
P1 0 get P0 0 get sub P1 1 get P0 1 get sub vlength /L exch def
P0 0 get P0 1 get moveto
P1 aload pop
P2 aload pop 
P3 0 get P2 0 get sub P3 1 get P2 1 get sub vlength /L exch def
P3 0 get P2 0 get sub hw L div mul /dx exch def
P3 1 get P2 1 get sub hw L div mul /dy exch def
P3 0 get dx sub P3 1 get dy sub
curveto
stroke
newpath
P3 aload pop translate
dx neg dy neg translate
P3 1 get P2 1 get sub
P3 0 get P2 0 get sub 
atan rotate
hw sw hw A B arrow
fill
grestore
end } def



% - closing arrows.inc ------------------------

/A 32 def
/B 67 def
/sw 0.032 def
/hw sw 3.4 mul def

gsave
newpath
A cos A sin sw hw 24 60 mkarrow
gsave
1 0.8 0.8 setrgbcolor
fill
grestore
stroke
grestore

gsave
B rotate
newpath
A cos A sin sw hw 24 60 mkarrow
gsave
1 0 0 setrgbcolor
fill
grestore
stroke
grestore

gsave
currentlinewidth 2.0 mul setlinewidth
newpath
0 0 0.5 A 10 add A B add 20 sub arc
stroke
grestore

grestore

gsave
28 40.13 translate
A B add 13 sub rotate 90 rotate
newpath
8 0 2.0 6 24 60 mkarrow
fill
grestore


