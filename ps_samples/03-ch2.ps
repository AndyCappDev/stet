%%BeginDocument: images2/pythagoras-plain.eps
%!PS-Adobe-2.0

%%BoundingBox: 0 0 160 172 


% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

% - Inserting box.inc ----------------------

% box.inc

/box {
2 dict begin

/h exch def
/w exch def

0 0 moveto
w 0 rlineto
0 h rlineto
w neg 0 rlineto
0 h neg rlineto
closepath

end
} def

/centred-box {
2 dict begin

/h exch def
/w exch def

w -0.5 mul h -0.5 mul moveto
w 0 rlineto
0 h rlineto
w neg 0 rlineto
0 h neg rlineto
closepath

end
} def

%[llx lly urx ury]

/rectangle {
4 dict begin

aload pop
/ury exch def
/urx exch def
/lly exch def
/llx exch def

llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
llx lly lineto
closepath

end
} def

% llx lly urx ury 

/bbox {
4 dict begin

/ury exch def
/urx exch def
/lly exch def
/llx exch def

llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
llx lly lineto
closepath

end
} def

/square {
1 dict begin

/s exch def

0 0 moveto
s 0 rlineto
0 s rlineto
s neg 0 rlineto
0 s neg rlineto
closepath
end
} def



% - closing box.inc ------------------------
160 172 box
clip

64 80 translate

72 dup scale
0.012 setlinewidth


% - Inserting pythagoras.inc ----------------------

/s 4.5 def
/a 2.5 s div def
/b 4 s div def
/c a a mul b b mul add sqrt def

/x a a mul c div def
/y a b mul c div def
/x1 b a mul c div def
/y1 b b mul c div def

/asquare {
0 0 moveto
x y lineto
y neg x rlineto
x neg y neg rlineto
closepath
} def

/arect {
0 0 moveto
x 0 lineto
0 c neg rlineto
x neg 0 rlineto
closepath
} def

/bsquare {
x y moveto
c 0 lineto
y c x sub rlineto
c x sub neg y rlineto
closepath
} def

/brect {
x 0 moveto
c 0 lineto
0 c neg rlineto
x c neg lineto
closepath
} def

/csquare {
0 0 moveto
c 0 lineto
0 c neg rlineto
c neg 0 rlineto
closepath
} def

/green { 0.5 0.5 0.5 } def
/lightgreen { 0.8 0.8 0.8 } def
/blue { 0.2 0.2 0.2 } def






% - closing pythagoras.inc ------------------------

x neg 0 translate

gsave
newpath
asquare
gsave
1 0 0 setrgbcolor
fill
grestore
stroke
grestore

gsave
newpath
bsquare
gsave
green setrgbcolor
fill
grestore
stroke
grestore

gsave
newpath
csquare
gsave
blue setrgbcolor
fill
grestore
stroke
grestore

