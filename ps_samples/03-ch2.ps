  [x y c add]
  [x y add y c add x sub]
  0.5 interpolate aload pop
lineto
  [c c]
  [c y add c x sub ]
  0.5 interpolate aload pop
lineto
  c 0 lineto
  x y lineto
closepath
fill
0 setgray
newpath
x y moveto
  [x y c add]
  [x y add y c add x sub]
  0.5 interpolate aload pop
lineto
  [c c]
  [c y add c x sub ]
  0.5 interpolate aload pop
lineto
  c 0 lineto
  x y lineto
closepath

stroke
grestore



