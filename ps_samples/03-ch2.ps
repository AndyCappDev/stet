1 0 0 setrgbcolor
newpath
0 0 moveto
  [0 c]
  [y neg x]
  0.5 interpolate aload pop
lineto
  [x y c add]
  [x y sub y x add]
  0.5 interpolate aload pop
lineto
  x y lineto
  0 0 lineto
closepath
