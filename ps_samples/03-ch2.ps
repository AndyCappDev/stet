[ 0 0 140 67 ] 

% - Inserting bbox.inc ----------------------

% [llx lly urx ury] on loading

% defines global variables llx urx lly ury width height

aload pop
/ury exch def
/urx exch def
/lly exch def
/llx exch def
/width urx llx sub def
/height ury lly sub def

% llx lly urx ury 

/box { 4 dict begin
/ury exch def
/urx exch def
/lly exch def
/llx exch def
llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
closepath
end } def

/boundary {
llx lly urx ury box
} def

/center {
llx lly translate
width 2 div height 2 div translate
} def

% - closing bbox.inc ------------------------

% - Inserting shears.inc ----------------------

/b 100 def
/a 63 def

% skew
/parallelogram { 1 dict begin
/s exch def
0 0 moveto
s b mul a lineto
b 0 rlineto
b 0 lineto
closepath
end } def

% - closing shears.inc ------------------------

% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

newpath
boundary 
clip

2 2 translate

1 setlinecap
1 setlinejoin

/s 1.37 def
/m a b div s div def

gsave
newpath
0 0 moveto
0 b m mul lineto
b s mul b sub a lineto
b 0 rlineto
closepath
gsave
1 0.8 0.8 setrgbcolor
fill
grestore
stroke
grestore

gsave
newpath
0 0 moveto
b 0 lineto
b m b mul lineto
closepath
stroke
grestore



