%%BeginDocument: images15/triangle.eps
%!PS-Adobe-2.0
%%BoundingBox: 0 0 120 100
[0 0 120 100]

% - Inserting bbox.inc ----------------------

% [llx lly urx ury] on loading

% defines global variables llx urx lly ury width height

aload pop
/ury exch def
/urx exch def
/lly exch def
/llx exch def
/width urx llx sub def
/height ury lly sub def

% llx lly urx ury 

/box { 4 dict begin
/ury exch def
/urx exch def
/lly exch def
/llx exch def
llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
closepath
end } def

/boundary {
llx lly urx ury box
} def

/center {
llx lly translate
width 2 div height 2 div translate
} def

% - closing bbox.inc ------------------------

newpath
boundary clip

gsave

12 12 translate

% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

/S 92 def
S dup scale
1 S div setlinewidth

gsave
1 0.9 dup setrgbcolor
newpath
-0.25 0 moveto
 1.25 0 lineto
0 -0.25 moveto
0 1 lineto
% stroke
grestore

gsave
newpath
0.5 0 moveto
1 0 lineto
0 0 1 0 60 arc
0.5 0 lineto
closepath
gsave
1 0.9 dup setrgbcolor
fill
grestore
1 0.6 dup setrgbcolor
stroke
grestore

/P [ 0.56 0.7 ] def

newpath
0 0 moveto
1 0 lineto
P aload pop lineto
closepath
stroke

gsave
newpath
P aload pop 
0.02 0 360 arc
gsave
0.5 setgray
fill
grestore
stroke
grestore

gsave
newpath
0 0
0.02 0 360 arc
gsave
1 setgray
fill
grestore
stroke
grestore

gsave
newpath
1 0 
0.02 0 360 arc
gsave
1 setgray
fill
grestore
stroke
grestore

grestore

gsave
79 55 translate

% - Inserting a.lbl ----------------------

