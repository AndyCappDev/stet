%%BeginDocument: images15/tr2.eps
%!PS-Adobe-2.0
%%BoundingBox: 0 0 80 108

% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

[ 0 0 80 108]

% - Inserting bbox.inc ----------------------

% [llx lly urx ury] on loading

% defines global variables llx urx lly ury width height

aload pop
/ury exch def
/urx exch def
/lly exch def
/llx exch def
/width urx llx sub def
/height ury lly sub def

% llx lly urx ury 

/box { 4 dict begin
/ury exch def
/urx exch def
/lly exch def
/llx exch def
llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
closepath
end } def

/boundary {
llx lly urx ury box
} def

/center {
llx lly translate
width 2 div height 2 div translate
} def

% - closing bbox.inc ------------------------
newpath boundary clip


gsave

/S 12 def
S dup scale
1 S div setlinewidth

3.5 8.5 translate

1 setlinejoin
1 setlinecap


% - Inserting P.inc ----------------------


/dx 0.8 def

/P [
[0 0]
[0.10 -1.25]
[0.25 dx add -2.5]
[0.25 dx 3 mul add -3.5]
[0.25 dx 1.0 mul add -4.5]
[0 -8]
[-1.75 -7]
[-2. -6]
[-3.25 -5]

] def
% - closing P.inc ------------------------

gsave
0 0 0 setrgbcolor
currentlinewidth 1 mul setlinewidth
newpath
P 0 get aload pop moveto
1 1 P length 1 sub { P exch get 
  aload pop lineto
} for
closepath
gsave
0.9 setgray
fill
grestore
stroke
grestore

/rad 0.19 def

newpath
P 0 get aload pop
rad 0 360 arc
gsave
1 0 0 setrgbcolor
fill
grestore
stroke

newpath
P 1 get aload pop
rad 0 360 arc
gsave
1 0 0 setrgbcolor
fill
grestore
stroke

newpath
P 2 get aload pop
rad 0 360 arc
gsave
1 0 0 setrgbcolor
fill
grestore
stroke

newpath
P 3 get aload pop
rad 0 360 arc
gsave
1 0 0 setrgbcolor
fill
grestore
stroke
grestore


