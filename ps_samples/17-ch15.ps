%%BeginDocument: images15/nm0.eps
%!PS-Adobe-2.0
%%BoundingBox: 0 0 96 96

% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------
[ 0 0 96 96]

% - Inserting bbox.inc ----------------------

% [llx lly urx ury] on loading

% defines global variables llx urx lly ury width height

aload pop
/ury exch def
/urx exch def
/lly exch def
/llx exch def
/width urx llx sub def
/height ury lly sub def

% llx lly urx ury 

/box { 4 dict begin
/ury exch def
/urx exch def
/lly exch def
/llx exch def
llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
closepath
end } def

/boundary {
llx lly urx ury box
} def

/center {
llx lly translate
width 2 div height 2 div translate
} def

% - closing bbox.inc ------------------------
newpath boundary clip

5 3 translate

/n 4 def

/S 8.1 def
S dup scale
1 S div setlinewidth

gsave


% - Inserting M.inc ----------------------


% - Inserting test.inc ----------------------


/P [
[3 0.2]
[10.2 3.5]
[11 10.3]
[9 9.4]
[8 11]
[6.6 5.3]
[3 8.7]
[1.6 7]
[2 4.3]
[4.2 5.8]
[3 2]
[0.4 3]
] def


% - closing test.inc ------------------------

{

/P [
[3 0.2]
[10.2 3.5]
[11 10.3]
[9 9.4]
[8 11]
[6.6 5.0]
[3 8.7]
[1.6 7]
[2 4.3]
[4.2 5.8]
[3 2]
[0.4 3]
] def

} pop

/fill-upper {
gsave
newpath
-5 P n get 1 get moveto
25 0 rlineto
0 20 rlineto
-25 0 rlineto
closepath
clip

0.90 setgray
newpath
P dup length 1 sub get aload pop moveto
P {
  aload pop lineto
} forall
fill
grestore

} def

% P Q t
/interpolate { 1 dict begin
/t exch def
/s 1 t sub def
/Q exch def
/P exch def
[
  P 0 get s mul Q 0 get t mul add
  P 1 get s mul Q 1 get t mul add
]
end } def

1 setlinejoin
1 setlinecap

% - closing test.inc ------------------------

fill-upper

gsave
0 0 0 setrgbcolor
currentlinewidth 1 mul setlinewidth
newpath
P dup length 1 sub get aload pop moveto
P {
  aload pop lineto
} forall
stroke
grestore

gsave
currentlinewidth 1.6 mul setlinewidth
1 0 0 setrgbcolor
newpath
P n get aload pop moveto
P n 1 add get aload pop lineto
stroke
grestore

gsave
currentlinewidth 1.6 mul setlinewidth
0.6 setgray
newpath
-4 P n get 1 get moveto
20 0 rlineto
stroke
grestore

/rad 0.29 def

gsave
0.06 setlinewidth

newpath
P n get aload pop rad 0 360 arc 
gsave
1 0 0 setrgbcolor
fill
grestore
stroke

grestore
grestore


