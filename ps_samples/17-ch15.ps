%%BeginDocument: images15/type1.eps
%!PS-Adobe-2.0
%%BoundingBox: 0 0 120 120
[0 0 120 120]

% - Inserting bbox.inc ----------------------

% [llx lly urx ury] on loading

% defines global variables llx urx lly ury width height

aload pop
/ury exch def
/urx exch def
/lly exch def
/llx exch def
/width urx llx sub def
/height ury lly sub def

% llx lly urx ury 

/box { 4 dict begin
/ury exch def
/urx exch def
/lly exch def
/llx exch def
llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
closepath
end } def

/boundary {
llx lly urx ury box
} def

/center {
llx lly translate
width 2 div height 2 div translate
} def

% - closing bbox.inc ------------------------


% - Inserting arrows.inc ----------------------


/cot { dup cos exch sin div } def

% arrowlength shaftwidth headwidth A B
% A B are angles at point, back of head 

/arrow {
12 dict begin
/B exch def
/A exch def
/headwidth exch def
/shaftwidth exch def
/w shaftwidth 0.5 mul def
/arrowlength exch def

/x headwidth 2 div A cot mul def
/y headwidth 2 div B cot mul def
/z shaftwidth 2 div B cot mul def

/shaftlength arrowlength x sub y add z sub def

currentlinecap 0 eq {
0 w neg moveto
0 w lineto
shaftlength w lineto
arrowlength x sub headwidth 0.5 mul lineto
arrowlength 0 lineto
arrowlength x sub headwidth -0.5 mul lineto
shaftlength w neg lineto
closepath
} if

currentlinecap 1 eq {
0 w neg moveto
0 0 w -90 90 arcn
shaftlength w lineto
arrowlength x sub headwidth 0.5 mul lineto
arrowlength 0 lineto
arrowlength x sub headwidth -0.5 mul lineto
shaftlength w neg lineto
closepath
} if

currentlinecap 2 eq {
w neg 0 moveto
w neg w lineto
shaftlength w lineto
arrowlength x sub headwidth 0.5 mul lineto
arrowlength 0 lineto
arrowlength x sub headwidth -0.5 mul lineto
shaftlength w neg lineto
w neg w neg lineto
closepath
} if

end
} def

% A = 24, B = 60 are good

% x y shaft-width head-width A B

/mkarrow {
12 dict begin
/B exch def
/A exch def
/headwidth exch def
/shaftwidth exch def
/y exch def
/x exch def
/C y x atan def
C rotate
/r x dup mul y dup mul add sqrt def
r shaftwidth headwidth A B arrow
C neg rotate
end } def

% draws along a Bezier curve
% P0 P1 P2 P3 sw hw A B

/fillcurvedarrow { 16 dict begin
gsave
/B exch def
/A exch def
/hw exch def
/sw exch def
/P3 exch def
/P2 exch def
/P1 exch def
/P0 exch def
newpath
sw setlinewidth
P1 0 get P0 0 get sub P1 1 get P0 1 get sub vlength /L exch def
P0 0 get P0 1 get moveto
P1 aload pop
P2 aload pop 
P3 0 get P2 0 get sub P3 1 get P2 1 get sub vlength /L exch def
P3 0 get P2 0 get sub hw L div mul /dx exch def
P3 1 get P2 1 get sub hw L div mul /dy exch def
P3 0 get dx sub P3 1 get dy sub
curveto
stroke
newpath
P3 aload pop translate
dx neg dy neg translate
P3 1 get P2 1 get sub
P3 0 get P2 0 get sub 
atan rotate
hw sw hw A B arrow
fill
grestore
end } def



% - closing arrows.inc ------------------------

gsave

1 setlinecap
1 setlinejoin

newpath
boundary
clip

gsave
0.9 setgray
newpath
boundary fill
grestore

width 2 div height 2 div translate
0 0 translate

/S 64 def
S dup scale
1 S div setlinewidth

/u [-0.5 -2] def

newpath
-2 0 moveto
 2 0 lineto
stroke

/sw 0.032 def
/hw 0.12 def

/v [ 0.1 0.8 ] def
gsave
newpath
v 0 get v 1 get sw hw 24 60 mkarrow
gsave
1 setgray
fill
grestore
currentlinewidth 2 div setlinewidth
stroke
grestore

/v [ 0.5 -0.8 ] def
gsave
newpath
v 0 get v 1 get sw hw 24 60 mkarrow
gsave
1 setgray
fill
grestore
currentlinewidth 2 div setlinewidth
stroke
grestore

/v [ -0.8 -0.5 ] def
gsave
newpath
v 0 get v 1 get sw hw 24 60 mkarrow
gsave
1 setgray
fill
grestore
currentlinewidth 2 div setlinewidth
stroke
grestore

/f -0.965 def

gsave
u 0 get u 1 get translate
newpath
u 0 get f mul u 1 get f mul sw hw 24 60 mkarrow
fill
grestore

newpath
0 0 0.05 0 360 arc
gsave
0.8 setgray
fill
grestore
stroke

grestore

/Helvetica-Bold findfont
9 scalefont
setfont

2 2 moveto
(start) show

26 92 moveto
(up) show

98 2 moveto
(split) show





