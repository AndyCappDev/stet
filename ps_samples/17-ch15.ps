%%BeginDocument: images15/end.eps
%!PS-Adobe-2.0
%%BoundingBox: 0 0 84 64

% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------
[0 0 84 64]

% - Inserting bbox.inc ----------------------

% [llx lly urx ury] on loading

% defines global variables llx urx lly ury width height

aload pop
/ury exch def
/urx exch def
/lly exch def
/llx exch def
/width urx llx sub def
/height ury lly sub def

% llx lly urx ury 

/box { 4 dict begin
/ury exch def
/urx exch def
/lly exch def
/llx exch def
llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
closepath
end } def

/boundary {
llx lly urx ury box
} def

/center {
llx lly translate
width 2 div height 2 div translate
} def

% - closing bbox.inc ------------------------


% - Inserting arrows.inc ----------------------


/cot { dup cos exch sin div } def

% arrowlength shaftwidth headwidth A B
% A B are angles at point, back of head 

/arrow {
12 dict begin
/B exch def
/A exch def
/headwidth exch def
/shaftwidth exch def
/w shaftwidth 0.5 mul def
/arrowlength exch def

/x headwidth 2 div A cot mul def
/y headwidth 2 div B cot mul def
/z shaftwidth 2 div B cot mul def

/shaftlength arrowlength x sub y add z sub def

currentlinecap 0 eq {
0 w neg moveto
0 w lineto
shaftlength w lineto
arrowlength x sub headwidth 0.5 mul lineto
arrowlength 0 lineto
arrowlength x sub headwidth -0.5 mul lineto
shaftlength w neg lineto
closepath
} if

currentlinecap 1 eq {
0 w neg moveto
0 0 w -90 90 arcn
shaftlength w lineto
arrowlength x sub headwidth 0.5 mul lineto
arrowlength 0 lineto
arrowlength x sub headwidth -0.5 mul lineto
shaftlength w neg lineto
closepath
} if

currentlinecap 2 eq {
w neg 0 moveto
w neg w lineto
shaftlength w lineto
arrowlength x sub headwidth 0.5 mul lineto
arrowlength 0 lineto
arrowlength x sub headwidth -0.5 mul lineto
shaftlength w neg lineto
w neg w neg lineto
closepath
} if

end
} def

% A = 24, B = 60 are good

% x y shaft-width head-width A B

/mkarrow {
12 dict begin
/B exch def
/A exch def
/headwidth exch def
/shaftwidth exch def
/y exch def
/x exch def
/C y x atan def
C rotate
/r x dup mul y dup mul add sqrt def
r shaftwidth headwidth A B arrow
C neg rotate
end } def

% draws along a Bezier curve
% P0 P1 P2 P3 sw hw A B

/fillcurvedarrow { 16 dict begin
gsave
/B exch def
/A exch def
/hw exch def
/sw exch def
/P3 exch def
/P2 exch def
/P1 exch def
/P0 exch def
newpath
sw setlinewidth
P1 0 get P0 0 get sub P1 1 get P0 1 get sub vlength /L exch def
P0 0 get P0 1 get moveto
P1 aload pop
P2 aload pop 
P3 0 get P2 0 get sub P3 1 get P2 1 get sub vlength /L exch def
P3 0 get P2 0 get sub hw L div mul /dx exch def
P3 1 get P2 1 get sub hw L div mul /dy exch def
P3 0 get dx sub P3 1 get dy sub
curveto
stroke
newpath
P3 aload pop translate
dx neg dy neg translate
P3 1 get P2 1 get sub
P3 0 get P2 0 get sub 
atan rotate
hw sw hw A B arrow
fill
grestore
end } def



% - closing arrows.inc ------------------------

gsave

newpath
boundary 
clip

1 setlinecap
1 setlinejoin

% u v
/delta { 1 dict begin
/v exch def
/u exch def
[ v 0 get u 0 get sub v 1 get u 1 get sub ]
end } def

% P Q t 
/interpolate { 1 dict begin
/t exch def
/Q exch def
/P exch def
/s 1 t sub def

[
  P 0 get s mul Q 0 get t mul add
  P 1 get s mul Q 1 get t mul add
]
end } def

/vscale { 1 dict begin
/c exch def
/v exch def
[ v 0 get c mul
v 1 get c mul ]
end } def

width 2 div height 2 div translate
0 20 translate

/S 48 def
S dup scale
1 S div setlinewidth

/P [2 2] def
/Q [0 -1.0] def
/R [-2 2] def

gsave
0.9 setgray
newpath
P aload pop moveto
Q aload pop lineto
R aload pop lineto
fill
grestore

/sw 0.032 def
/hw 0.14 def

sw setlinewidth

gsave
newpath
R aload pop moveto
Q aload pop lineto
stroke
grestore

gsave
R aload pop translate
newpath
R Q delta 0.8 vscale aload pop sw hw 24 60 mkarrow
fill
grestore

gsave
newpath
P aload pop moveto
Q aload pop lineto
stroke
grestore


gsave
Q aload pop translate
newpath
Q P delta 0.26 vscale aload pop sw hw 24 60 mkarrow
fill
grestore


% - Inserting V.inc ----------------------

/rad 0.056 def

% - closing V.inc ------------------------

gsave
newpath
