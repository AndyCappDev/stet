%%BeginDocument: images15/diagonal.eps
%!PS-Adobe-2.0
%%BoundingBox: 0 0 100 100

% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

[0 0 100 100]

% - Inserting bbox.inc ----------------------

% [llx lly urx ury] on loading

% defines global variables llx urx lly ury width height

aload pop
/ury exch def
/urx exch def
/lly exch def
/llx exch def
/width urx llx sub def
/height ury lly sub def

% llx lly urx ury 

/box { 4 dict begin
/ury exch def
/urx exch def
/lly exch def
/llx exch def
llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
closepath
end } def

/boundary {
llx lly urx ury box
} def

/center {
llx lly translate
width 2 div height 2 div translate
} def

% - closing bbox.inc ------------------------
newpath boundary clip

gsave
newpath
boundary
0.9 setgray
fill
grestore


width 2 div height 2 div translate

/S 64 def
S dup scale
1 S div setlinewidth

/P [
  [0.5 1.5]
  [-0.25 0.25]
  [-1 1]
] def

/Q [
  [-0.25 -1]
  [0 -0.25]
  [1.75 0.25]
] def

/uP [ 
  P 1 get 0 get P 0 get 0 get sub 
  P 1 get 1 get P 0 get 1 get sub 
] def
/vP [
  P 2 get 0 get P 1 get 0 get sub 
  P 2 get 1 get P 1 get 1 get sub 
] def

/uQ [ 
  Q 1 get 0 get Q 0 get 0 get sub 
  Q 1 get 1 get Q 0 get 1 get sub 
] def
/vQ [
  Q 2 get 0 get Q 1 get 0 get sub 
  Q 2 get 1 get Q 1 get 1 get sub 
] def

gsave
0.6 0 dup setrgbcolor
newpath
P 1 get aload pop moveto
Q 1 get aload pop lineto
stroke
grestore

newpath
P 0 get aload pop moveto
P 1 get aload pop lineto
P 2 get aload pop lineto
gsave
1 setgray
fill
grestore
stroke

newpath
2 -2 moveto
Q 0 get aload pop lineto
Q 1 get aload pop lineto
Q 2 get aload pop lineto
gsave
1 setgray
fill
grestore
stroke


% - Inserting arrows.inc ----------------------


/cot { dup cos exch sin div } def

% arrowlength shaftwidth headwidth A B
% A B are angles at point, back of head 

/arrow {
12 dict begin
/B exch def
/A exch def
/headwidth exch def
/shaftwidth exch def
/w shaftwidth 0.5 mul def
/arrowlength exch def

/x headwidth 2 div A cot mul def
/y headwidth 2 div B cot mul def
/z shaftwidth 2 div B cot mul def

/shaftlength arrowlength x sub y add z sub def

currentlinecap 0 eq {
0 w neg moveto
0 w lineto
shaftlength w lineto
arrowlength x sub headwidth 0.5 mul lineto
arrowlength 0 lineto
arrowlength x sub headwidth -0.5 mul lineto
shaftlength w neg lineto
closepath
} if

currentlinecap 1 eq {
0 w neg moveto
0 0 w -90 90 arcn
shaftlength w lineto
arrowlength x sub headwidth 0.5 mul lineto
arrowlength 0 lineto
arrowlength x sub headwidth -0.5 mul lineto
shaftlength w neg lineto
closepath
} if

currentlinecap 2 eq {
w neg 0 moveto
w neg w lineto
shaftlength w lineto
arrowlength x sub headwidth 0.5 mul lineto
arrowlength 0 lineto
arrowlength x sub headwidth -0.5 mul lineto
shaftlength w neg lineto
w neg w neg lineto
closepath
} if

end
} def

% A = 24, B = 60 are good

% x y shaft-width head-width A B

/mkarrow {
12 dict begin
/B exch def
/A exch def
/headwidth exch def
/shaftwidth exch def
/y exch def
/x exch def
/C y x atan def
C rotate
/r x dup mul y dup mul add sqrt def
r shaftwidth headwidth A B arrow
C neg rotate
end } def

% draws along a Bezier curve
% P0 P1 P2 P3 sw hw A B

/fillcurvedarrow { 16 dict begin
gsave
/B exch def
/A exch def
/hw exch def
/sw exch def
/P3 exch def
/P2 exch def
/P1 exch def
/P0 exch def
newpath
sw setlinewidth
P1 0 get P0 0 get sub P1 1 get P0 1 get sub vlength /L exch def
P0 0 get P0 1 get moveto
P1 aload pop
P2 aload pop 
P3 0 get P2 0 get sub P3 1 get P2 1 get sub vlength /L exch def
P3 0 get P2 0 get sub hw L div mul /dx exch def
P3 1 get P2 1 get sub hw L div mul /dy exch def
P3 0 get dx sub P3 1 get dy sub
curveto
stroke
newpath
P3 aload pop translate
dx neg dy neg translate
P3 1 get P2 1 get sub
P3 0 get P2 0 get sub 
atan rotate
hw sw hw A B arrow
fill
grestore
end } def



% - closing arrows.inc ------------------------

/sw currentlinewidth def
/hw sw 4.4 mul def

gsave
/f 0.8 def
newpath
P 0 get aload pop translate
uP 0 get f mul uP 1 get f mul sw hw 24 60 mkarrow
fill
grestore

gsave
/f 0.4 def
newpath
P 1 get aload pop translate
vP 0 get f mul vP 1 get f mul sw hw 24 60 mkarrow
fill
grestore

gsave
/f 0.2 def
newpath
Q 1 get aload pop translate
vQ 0 get f mul vQ 1 get f mul sw hw 24 60 mkarrow
fill
grestore

gsave
/f 0.6 def
newpath
Q 0 get aload pop translate
uQ 0 get f mul uQ 1 get f mul sw hw 24 60 mkarrow
fill
grestore

/rad 0.03 def

gsave
newpath
P 1 get aload pop rad 0 360 arc 
gsave
1 0 0 setrgbcolor
fill
grestore
stroke
grestore

gsave
newpath
Q 1 get aload pop rad 0 360 arc 
gsave
1 0 0 setrgbcolor
fill
grestore
stroke
grestore




