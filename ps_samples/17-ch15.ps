shaftlength w lineto
arrowlength x sub headwidth 0.5 mul lineto
arrowlength 0 lineto
arrowlength x sub headwidth -0.5 mul lineto
shaftlength w neg lineto
closepath
} if

currentlinecap 1 eq {
0 w neg moveto
0 0 w -90 90 arcn
shaftlength w lineto
arrowlength x sub headwidth 0.5 mul lineto
arrowlength 0 lineto
arrowlength x sub headwidth -0.5 mul lineto
shaftlength w neg lineto
closepath
} if

currentlinecap 2 eq {
w neg 0 moveto
w neg w lineto
shaftlength w lineto
arrowlength x sub headwidth 0.5 mul lineto
arrowlength 0 lineto
arrowlength x sub headwidth -0.5 mul lineto
shaftlength w neg lineto
w neg w neg lineto
closepath
} if

end
} def

% A = 24, B = 60 are good

% x y shaft-width head-width A B

/mkarrow {
12 dict begin
/B exch def
/A exch def
/headwidth exch def
/shaftwidth exch def
/y exch def
/x exch def
/C y x atan def
C rotate
/r x dup mul y dup mul add sqrt def
r shaftwidth headwidth A B arrow
C neg rotate
end } def

% draws along a Bezier curve
% P0 P1 P2 P3 sw hw A B

/fillcurvedarrow { 16 dict begin
gsave
/B exch def
/A exch def
/hw exch def
/sw exch def
/P3 exch def
/P2 exch def
