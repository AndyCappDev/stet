1 setlinejoin
1 setlinecap

gsave
currentlinewidth 1 mul setlinewidth
0 0 0 setrgbcolor
newpath
P dup length 1 sub get aload pop moveto
P {
  aload pop lineto
} forall
stroke
grestore

P 3 triangulation  % an array of triangles
{
  /X exch def
  newpath
  X 0 get aload pop moveto
  X 1 get aload pop lineto
  X 2 get aload pop lineto
  closepath
  stroke
} forall



