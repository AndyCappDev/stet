% - Inserting stack.inc ----------------------

%! stack.inc
%  a stack = [ array integer ]
%  the integer is the current stack size
%
%  <n> new-stack: returns a new stack of potential size n
%  <x> <stack> stack-push: pushes x onto the stack
%  <stack> stack-pop: removes the current stack top and returns it
%  <stack> stack-peek: returns the current stack top
%  <stack> stack-length: returns current size
%  <stack> stack-empty: empty or not?
%  <stack> stack-extend: doubles the size
%  <stack> stack-array: reurns an array of exactly the right size
%  n <stack> stack-element-at: element at position n from bottom
%
%  no checks are made on arrays

/stack.inc true def

% n -> [[array of length n] 0]
/new-stack {
  [ exch array 0 ]
} def

% x stack
/stack-push { % x s
  aload % x a n s 
  3 1 roll dup  % x s a n n
  3 1 roll	% x s n a n
  5 -1 roll      % s n a n x
put 		% s n
1 exch 1 add put
} def

% i stack 
/stack-element-at {
  0 get exch get
} def

% stack
/stack-pop { % s
  aload 3 1 roll	% s a n
  1 sub dup 3 1 roll	% s n-1 a n-1
  get	% s n-1 a[n-1]
  3 1 roll  % a[n-1] s n-1
  1 exch put
} def

% stack
/stack-peek { % stack
  aload pop % array size
  1 sub get
} def

% stack
/stack-empty {
  1 get 0 eq
} def

% stack
/stack-full {
  aload pop exch length eq
} def

% stack
/stack-length {
  1 get
} def

% stack -> doubled potential length
/stack-extend { 
  aload 0 % a n s 0
  4 2 roll pop % s 0 a 
  [ exch % s 0 [ a 
  aload length % s 0 [ ... ell
  { null } repeat ] % s 0 [...]
  put 
} def

/stack-array { % s
aload pop % a n
[ 3 1 roll	% [ a n 
exch aload length % [ n <ell> ell
dup 2 add -1 roll sub % % [ ... ell-n 
{ pop } repeat
]
} def

% -------------------------------------------------

% - closing stack.inc ------------------------


% - Inserting sort.inc ----------------------

%!

/sort.inc true def

/qsortdict 8 dict def

qsortdict begin

% args: /comp a L R x
% effect: effects a partition into two pieces [L j] [i R]
%     leaves i j on stack

/partition { 8 dict begin
/x exch def
/j exch def
/i exch def
/a exch def
load /comp exch def
{
  {
    a i get x comp exec not {
      exit
    } if
    /i i 1 add def
  } loop
  {
    x a j get comp exec not {
      exit
    } if
    /j j 1 sub def
  } loop
  
  i j le {
    % swap a[i] a[j]
    a j a i get
    a i a j get 
    put put
    /i i 1 add def
    /j j 1 sub def
  } if
  i j gt {
    exit
  } if
} loop
i j
end } def

% args: /comp a L R
% effect: sorts a[L .. R] according to comp

/subsort {
% /c a L R
[ 3 1 roll ] 3 copy
% /c a [L R] /c a [L R]
aload aload pop 
% /c a [L R] /c a L R L R
add 2 idiv
% /c a [L R] /c a L R (L+R)/2
3 index exch get
% /c a [L R] /c a L R x
partition
% /c a [L R] i j
% if j > L subsort(a, L, j)
dup 
% /c a [L R] i j j
3 index 0 get gt {
  % /c a [L R] i j
  5 copy 
  % /c a [L R] i j /c a [L R] i j
  exch pop
  % /c a [L R] i j /c a [L R] j
  exch 0 get exch
  % ... /c a L j 
  subsort
} if
% /c a [L R] i j
pop dup
% /c a [L R] i i
% if i < R subsort(a, i, R)
2 index 1 get lt {
  % /c a [L R] i
  exch 1 get 
  % /c a i R
  subsort
}{
  4 { pop } repeat
} ifelse
} def

end

% args: /comp a
% effect: sorts the array a 
% comp returns truth of x < y for entries in a

/quicksort { qsortdict begin
dup length 1 gt {
% /comp a
dup 
% /comp a a 
length 1 sub 
% /comp a n-1
0 exch subsort
} {
pop pop
} ifelse
end } def

% ----------------------------------------



% - closing sort.inc ------------------------


% - Inserting dynamic-tree.inc ----------------------

%!

/dynamic-tree.inc true def

% This search tree orders objects keyed by real numbers.
% The assignment of a real number to an item
% in the list is dynamic---it is calculated each time it is needed
% by applying a function called the key-procedure to
% two arguments: (1) a global one stored as data in the root
% and (2) a local one, the item itself.

% Procedures available in this file: 

% * <key-procedure> new-tree
%
% The key procedure is a function 
% with two arguments >global> <local> that returns a real number.
% The first is root's <data>, the second
% a node's data.

% * <data> <tree root> tree-insert
% Inserts a node associated to <data> in the tree.
% This returns the node, to be used in a call for removal later on.
% If not to be reused, it must be popped.

% <real number> <tree-root> tree-predecessor
%
% Returns the data in the tree just prior to the real number.

% * <node> <tree-root> tree-remove 
%
% Removes the node from the tree.  This node will usually
% be the one returned by insertion.

% For example, a tree storing only a list of real numbers
% would have data equal to a single real number 
% and its key procedure would be { exch pop } - i.e. it would do nothing,
% in effect feeding the data out as the key.  

% In addition, for debugging we have <root> tree-list,
% which returns an ordered array of the data in the tree
% and <root> tree-print, which prints out the tree data as well as its structure.

% ---------------------------------------------------

% A normal tree node = [ left right data parent ]
%               root = [ left right data key-procedure ]
%
% The root's right is always null.

% -----------------------------
% delete these after a while: 
/LEFT 0 def
/RIGHT 1 def
/DATA 2 def
/PARENT 3 def
/HEAD LEFT def
/PROC 3 def
% -----------------------------

% argument: key-procedure
% returns: the root = [ null null null key-proc ]
/new-tree {
  [ exch     % [ key-proc
  null dup dup % [ key-proc null null null
  4 -1 roll ]  % [ null null null key-proc ]
} def

% arguments: data tree-root
% returns: inserted the node string the data
/tree-insert { 1 dict begin
/root exch def
/data exch def
/g root DATA get def
/key-proc root PROC get def
/key g data key-proc def
/p root def
/q root HEAD get def
{
  q null eq { exit } if
  /p q def
  key 
    g q DATA get key-proc 
  lt { /q q LEFT get def }{ /q q RIGHT get def } ifelse
} loop 
/q [ null dup data p ] def
p root eq { p HEAD q put }{
  key 
    g p DATA get key-proc 
  lt
  { p LEFT q put }{ p RIGHT q put } ifelse
} ifelse
q 
  % (= inserted =================) =
  % root tree-print
  % (----------------------------) = 

end } def

% real-number root
% returns: the predecessor data, null if no predecessor
/tree-predecessor { 1 dict begin
/root exch def
/x exch def
/key-proc root PROC get def
/p root HEAD get def
/g root DATA get def
/found null def
{ 
  p null eq { exit } if
  g p DATA get key-proc x lt { % p < x
    /found p def
    p RIGHT get null eq { exit } if
    /p p RIGHT get def
  }{ % p >= x
    /p p LEFT get def
  } ifelse
} loop
found null eq { null }{ found DATA get } ifelse
end } def

% --- removal -----------------------------------------------

% node root
/tree-remove { 1 dict begin
/root exch def
 % pop % don't really need the root!
/node exch def
/p node PARENT get def

% (= removing =================) =
% node DATA get eprint 

node LEFT get null eq {
  % (left null) == 
  % replace this node by its unique (right) child
  /q node RIGHT get def
  p LEFT get node eq {
    p LEFT q put
  }{
    p RIGHT q put
  } ifelse
  q null ne { q PARENT p put } if
}{
  % (left not null) == 
  % node LEFT != null
  % replace the node with its predecessor
  /q node LEFT get def % not null
  % q DATA get eprint
  /r q RIGHT get def
  r null eq {
    % (r null) == 
    % replace the node by its left child q
    % q is the predecessor
    /r node RIGHT get def
    p LEFT get node eq {
      p LEFT q put
    }{
      p RIGHT q put
    } ifelse
    q null ne { q PARENT p put } if
    q RIGHT r put
    r null ne { r PARENT q put } if
  }{
    % (r not null) == 
    % q -> r on right, neither = null
    % q = r's parent is not going to disappear
    % two replacements to make: high and low
    {
      /s r RIGHT get def
	  s null eq { exit } if
      /r s def
    } loop
    % now r = predecessor
    % replace r locally
    /s r PARENT get def
    /t r LEFT get def
    s RIGHT t put
    t null ne { t PARENT s put } if

    % replace node by r
    % q = NODE->left, non-null
    r LEFT q put
    q PARENT r put
    p LEFT get node eq {
      p LEFT r put
    }{
      p RIGHT r put
    } ifelse
    r PARENT p put

    % attach node's right child to r
    /s node RIGHT get def
    r RIGHT s put
    s null ne { s PARENT r put } if
  } ifelse
} ifelse

 % (= removed =================) =
 % node DATA get eprint
 % root tree-print
 % (----------------------------) = 

end } def

% -----------------------------------

% tree-root
/tree-list { 1 dict begin
  [ exch HEAD get tree-list-recursive ] 
end } def

% node
/tree-list-recursive { 1 dict begin
  /node exch def
  node null eq not {
    node LEFT get tree-list-recursive
    node DATA get
    node RIGHT get tree-list-recursive
  } if
end } def

% ------------------------------------

% tree-root
/tree-print { 1 dict begin
  HEAD get 0 tree-print-recursive 
end } def

% node
/tree-print-recursive { 1 dict begin
  /d exch def
  /node exch def
  node null ne {
    [ d { (*) } repeat node DATA get /e exch def e 0 get 0 get e 1 get 0 get ] == 
    % [ d { (*) } repeat node DATA get ] == 
    node LEFT get null ne node RIGHT get null ne or {
      node LEFT get d 1 add tree-print-recursive
      node RIGHT get d 1 add tree-print-recursive
    } if
  }{
    [ d { (*) } repeat null ] == 
  } ifelse
end } def

% ------------------------------------------------------

% - closing dynamic-tree.inc ------------------------

/triangulationdict 16 dict def

/triangulation.inc true def

triangulationdict begin

/START 0 def
/END 1 def
/SPLIT 2 def
/MERGE 3 def
/UP 4 def
/DOWN 5 def

/type-name [ (start) (end) (split) (merge) (up) (down) ] def

% --- vertex and edge structure -----------------------

% vertex = [  2Dpoint predecessor-edge successor-edge type index ]
% edge = [  start-vertex end-vertex [ABC] helper tree-node ]

% [ p e0 e1 type i ]
/vprint { 1 dict begin
/v exch def
 [ v 0 get type-name v 3 get get v 4 get ] ==
end } def

% [ src tar [ABC] helper node ]
/eprint { 1 dict begin
/e exch def
 [ e 0 get 0 get e 1 get 0 get e 2 get ] ==
end } def

% --- general utilities -------------------------------

% clones any array
/clone { 
  [ exch { } forall ]
} def

/dot-product { % u v
  aload pop % u v0 v1
  3 -1 roll aload pop % v0 v1 u0 u1
  3 -1 roll           % v0 u0 u1 v1
  mul                 % v0 u0 u1.v1
  3 1 roll mul        % u1.v1 v0.u0
  add
} def

% -----------------------------------------------------

% if not up, then down
% left to right is up
% argument: [ x y ]
% returns: true/false
/goes-up {
  % u
  aload pop % x y
  dup 0 gt  % x y y>0?
    3 1 roll % y>0? x y
    0 eq % y>0? x y=0? 
    exch 0 lt % y>0? y=0? x<0?
    and 
  or 
} def

% P Q -> [ A B C ]
% Ax + By + C = 0 on the segment
% positive on the left bank
/abc { 1 dict begin
  /Q exch def
  /P exch def
  /x Q 0 get P 0 get sub def
  /y Q 1 get P 1 get sub def
  [ y neg x P 0 get y mul P 1 get x mul sub ]
end } def

% u v -> type of vertex: start etc.
/get-type { 1 dict begin
/v exch def
/u exch def
/w [ u 1 get neg u 0 get ] def % uperp
u goes-up { 
  v goes-up { //UP }{
    v w dot-product 0 gt { //START } { //SPLIT } ifelse
  } ifelse
}{ % u goes down
  v goes-up not { //DOWN }{
    v w dot-product 0 gt { //END } { //MERGE } ifelse
  } ifelse
} ifelse
end } def

% edge -> Q-P
/delta { 1 dict begin
/e exch def
/Q e 1 get 0 get def
/P e 0 get 0 get def
[ Q 0 get P 0 get sub 
  Q 1 get P 1 get sub ]
end } def

% U V: vertices
% returns: U above or to the left of V
/less-than { 1 dict begin
0 get aload pop 
/y1 exch def
/x1 exch def
0 get aload pop 
/y0 exch def 
/x0 exch def
y0 y1 gt
  y0 y1 eq 
  x0 x1 lt and
or 
end } def

% --- vertex actions in the top-down sweep -----------------------

% in the next few procedures, V, list, and N are global variables
% i.e. defined in the context in which they are called

% making a diagonal: 
 % just store source and target here, later decompose
% the diagonal becomes an edge for two polygons

/handle-start { 1 dict begin
  % set s = successor edge
  /s V 2 get def
  % set the current value of y
  list DATA V 0 get 1 get put
  % put s in the search tree
  % and set its node in s
  s dup 4 exch list tree-insert put
  % set V = helper for s

  s 3 V put 
end } def

/handle-end { 1 dict begin
% e = predecessor of V
/e V 1 get def
 % e eprint 
% h = e's helper
/h e 3 get def
h 3 get MERGE eq {
  % make a diagonal from h to V
  h V make-diagonal
} if
e 4 get list tree-remove
N 
end /N exch def
} def

/handle-split { 1 dict begin
% e = edge just to the left of V
/x V 0 get 0 get def
% set the current value of y
list DATA V 0 get 1 get put
/e x list tree-predecessor def

% h = helper of e
/h e 3 get def
/f V 2 get def
% make a diagonal from V to h
V h make-diagonal
% new helper of e = V
e 3 V put
% put successor edge of V in the list
f dup 4 exch list tree-insert put
% f's helper is its source (no longer V)
f 3 f 0 get put
N 
end /N exch def
} def

/handle-merge { 1 dict begin
% e is predecessor of V
/e V 1 get def
% h = helper of e
/h e 3 get def
h 3 get MERGE eq {
  % make diagonal h to V
  h V make-diagonal
} if
e 4 get list tree-remove
/x V 0 get 0 get def
% f is just left of V
% set the current value of y
list DATA V 0 get 1 get put
/f x list tree-predecessor def
/h f 3 
get def
h 3 get MERGE eq {
  % make diagonal V to h
  V h make-diagonal
} if
% new helper of f = V
f 3 V put
N 
end /N exch def } def

/handle-up { 1 dict begin
/x V 0 get 0 get def
% set the current value of y
list DATA V 0 get 1 get put
/e x list tree-predecessor def
/h e 3 get def
h 3 get MERGE eq {
  % make diagonal h to V
  V h make-diagonal
} if
% set helper of e = V
e 3 V put
N
end /N exch def
} def

/handle-down { 1 dict begin
% e = predecessor of V
/e V 1 get def
/h e 3 get def
% f = V's successor
/f V 2 get def
h 3 get MERGE eq {
  % make diagonal h to V
  h V make-diagonal
} if
  % list tree-print
e 4 get list tree-remove
% insert the successor in the search tree
% set the current value of y
list DATA V 0 get 1 get put
f dup 4 exch list tree-insert put
f 3 f 0 get put
N 
end /N exch def } def

/handle-vertex [
  /handle-start load
  /handle-end load
  /handle-split load
  /handle-merge load
  /handle-up load
  /handle-down load
] def

% --- making diagonals ----------------------------------------

% a line segment: vertices V0 and V1
/make-diagonal { 1 dict begin 

  /V1 exch def
  /V0 exch def
  /e0 V0 1 get def
  /f1 V0 2 get def
  /e1 V1 2 get def
  /f0 V1 1 get def

  /U0 [ V1 0 get f0 null V1 3 get N       ] def % d1
  /U1 [ V0 0 get null f1 V0 3 get N 1 add ] def % d1

  /d0 [ V0 V1 V0 0 get V1 0 get abc ] def % down
  /d1 [ U0 U1 U0 0 get U1 0 get abc ] def % up
  V0 2 d0 put
  V1 1 d0 put
  U0 2 d1 put
  U1 1 d1 put

  e0 1 V0 put
  e1 0 V1 put
  f0 1 U0 put
  f1 0 U1 put
  N 2 add

end /N exch def } def

% --- the key-procedure for the search tree -------------------

% arguments: current value of y & edge 
% returns: x-coordinate of intersection of sweep line with the edge
/Key { 1 dict begin
  /e exch def 
  /y exch def
  e 2 get aload pop 
  /C exch def
  /B exch def
  /A exch def
  A 0 eq { % get x for first vertex of e
    e 0 get 0 get 0 get
  }{
    B y mul C add A div neg
  } ifelse
end } def

/true-mod { % a b
  dup 3 1 roll	% b a b
  mod           % b a-mod-b
  dup 0 lt { % b a-mod-b
    add
  }{ 
    exch pop 
  } ifelse
} def

% C A B -> line A -> B has C on right
/is-right-of { 1 dict begin
/B exch def
/A exch def
/C exch def
% (B-A)^perp . (C-A) > 0?
  A 1 get B 1 get sub 
  C 0 get A 0 get sub mul
  B 0 get A 0 get sub  
  C 1 get A 1 get sub mul
add 0 lt
end } def

% [P Q R] -> true/false
/is-positive {
  aload pop
  /R exch def
  /Q exch def
  /P exch def
  % (Q-P)^perp . (R-P) > 0?
    Q 1 get P 1 get sub
    R 1 get P 1 get sub
    mul
    P 0 get Q 0 get sub
    R 0 get P 0 get sub
    mul
  add 0 gt
} def

% P Q
/distance { % P Q
  aload pop                        % P xQ yQ
  3 -1 roll aload pop               % xQ yQ xP yP
  3 -1 roll sub dup mul            % xQ xP (yQ-yP)^2
  3 1 roll sub dup mul
  add sqrt
} def

% [ BC AC AB a b c ] gets rearraneged so 0 < a <= b <= c
/ordered { 1 dict begin
  aload pop 
  /c exch def
  /b exch def
  /a exch def  % BC AC AB
  [ 4 1 roll   % [ BC AC AB
  b c le { % b < c
    a b le { % a < b < c
      a b c ]
    }{ % b < a, b < c
      a c le { % b < a < c
         % 2 1 3
         3 1 roll exch 3 -1 roll b a c ]
      }{ % b < c < a
         % 3 1 2
         3 -1 roll b c a ]
      } ifelse
    } ifelse
  }{ % c < b
    b a le { % c < b < a
      % 3 2 1
      3 1 roll exch c b a ]
    }{ % a < b, c < b
      a c le {
        % 1 3 2
        exch a c b ]
      }{ % c < a < b
        % 2 3 1
        3 1 roll c a b ]
      } ifelse
    } ifelse
  } ifelse
end } def

/SQRT2 2 sqrt def

end % --- of triangulation dictionary ------------------------------

% argument: a polygon = array of 2D points p[i], of length at least 3
% returns: an array of polygons, the monotone decomposition
/monotone { triangulationdict begin
1 dict begin
/polygon exch def
/N polygon length def
/vertex N array def
/edge N array def

/list /Key load new-tree def

0 1 N 1 sub { /i exch def
  /P polygon i get def
  /Q polygon i 1 add N mod get def
  vertex i [ P null null null i ] put
  edge i [ P Q 2 copy abc null null ] put
} for 

0 1 N 1 sub { /i exch def
  /j i 1 sub def
  j 0 lt { /j N 1 sub def } if
  vertex i get 1 edge j get put 
  vertex i get 2 edge i get put 
  edge i get 0 vertex i get put
  edge i get 1 vertex i 1 add N mod get put
} for

0 1 N 1 sub { /i exch def
  /V vertex i get def
  /u V 1 get delta def
  /v V 2 get delta def
  V 3 u v get-type put
} for

/queue vertex clone def
/less-than queue
quicksort 

queue { /V exch def
  /type V 3 get def
  % V vprint 
  handle-vertex type get exec
} forall

/Vertex N array def
% scan through the edges, going from source to target
% assembling polygons
% when a vertex is encountered, set a flag in Vertex

[
edge {
  /e exch def
  /V e 0 get def
  /k V 4 get def
  Vertex k get null eq { % starting a new component
    [
    {
      Vertex k true put
      V 0 get % the 2D point is put on the stack
      % let e = V's successor ...
      /e V 2 get def
      % ... and then set V = e's end vertex
      /V e 1 get def
      /k V 4 get def
      Vertex k get null ne { exit } if
    } loop
    ]
  } if
} forall
]
end end } def

% --- end of monotone ------------------------------------

% --- triangulation proper -------------------------------

/monotone-triangulate { triangulationdict begin
1 dict begin
  /P exch def
  % P = array of 2D points
  /N P length def

  % make up an array of the points of P sorted by height, associated to side
  /max P 0 get 1 get def
  /m 0 def
  1 1 N 1 sub { /i exch def
    /y P i get 1 get def
    y max gt {
      /m i def
      /max y def
    } if
  } for
  % P[m] is the highest point
  % arrange points top to bottom
  % merging left and right
  /l m 1 add N mod def
  /L P l get def
  /yl L 1 get def
  /r m 1 sub N true-mod def
  /R P r get def
  /yr R 1 get def
  % 0 = left, 1 = right
  [ 
  [ P m get 0 ]
  {
    % [ r l ] ==
    r l eq { % push one & quit
      [ L 0 ]
      exit 
    } if
    yl yr gt
      yl yr eq L 0 get R 0 get lt and
    or {
      % put L
      [ L 0 ]
      /l l 1 add N mod def
      /L P l get def
      /yl L 1 get def
    }{
      % put R
      [ R 1 ]
      /r r 1 sub N true-mod def
      /R P r get def
      /yr R 1 get def
    } ifelse
  } loop
  ] /P exch def

  % P is now an array of [ [x y] side ]
  [
  /stack N new-stack def
  P 0 get stack stack-push
  P 1 get stack stack-push
  % there are always at least two items on the stack
  2 1 N 1 sub { /i exch def
  % stack stack-array == (---) =
    P i get aload pop
    /vs exch def /v exch def
    stack stack-pop aload pop
    /us exch def /u exch def
    vs 0 eq { % v is on the left 
      us 0 eq { % u, v both on left
        /a u def
        { % at least one item still on stack
          /b stack stack-pop 0 get def

          % check: v on right of a -> b?
          v a b is-right-of {
            % make a triangle
            [v b a]
          }{
            % push back some stuff and quit
            [b 0] stack stack-push
            [a 0] stack stack-push
            [v 0] stack stack-push
            exit
          } ifelse
          stack stack-empty {
            [b 0] stack stack-push 
            [v 0] stack stack-push
            exit 
          } if
          /a b def
        } loop
      }{ % v on left, u on right
        /a u def
        {
          /b stack stack-pop 0 get def
          % make a triangle v a b
          [v a b]
          stack stack-empty {
            [u 1] stack stack-push 
            [v 0] stack stack-push
            exit 
          } if
          /a b def
        } loop
      } ifelse
    }{
      us 1 eq { % u, v both on right
        /a u def
        {
          /b stack stack-pop 0 get def
          % check: v on right of a -> b?
          v b a is-right-of {
            % make a triangle
            [v a b]
          }{
            % push back some stuff and quit
            [b 1] stack stack-push
            [a 1] stack stack-push
            [v 1] stack stack-push
            exit
          } ifelse
          stack stack-empty {
            [b 1] stack stack-push 
            [v 1] stack stack-push
            exit 
      aload pop moveto
          } if
          /a b def
        } loop
      }{ % v on right, u on left
        /a u def
        {
          /b stack stack-pop 0 get def
          % make a triangle v b a (opposite orientation from other case)
          [v b a]
          stack stack-empty {
            [u 0] stack stack-push 
            [v 1] stack stack-push
            exit 
          } if
          /a b def
        } loop
      } ifelse

    } ifelse
  } for
  ] 

end end } def

% --- small triangles -----------------------------------------

% arguments: triangle & delta
% returns: array of triangles of diameter at most delta
/subdivide { triangulationdict begin
1 dict begin
  /delta exch def
  aload pop 
  /R exch def
  /Q exch def
  /P exch def
  /pq P Q distance def
  /pr P R distance def
  /qr Q R distance def
  /T [P Q R qr pr pq] ordered def
  % T ==
  T 5 get delta gt {
    /stack T 5 get 2 sqrt div delta div log SQRT2 ln div cvi 1 add 4 mul new-stack def
    T stack stack-push 
  }{
    /stack 0 new-stack def
    T 
  } ifelse
  [
    { 
      stack stack-empty {
        exit 
      } if
      % stack is now not empty
      /T stack stack-pop def
      % T ==
      % T = [ A B C a b c ] needs subdivision
        T aload pop 
        /c exch def
        /b exch def
        /a exch def
        /C exch def
        /B exch def
        /A exch def
        /a T 3 get def
        /b T 4 get def
        /c T 5 get def
        b c div SQRT2 le { % line to bottom mid-point
          /AB [ A 0 get B 0 get add 0.5 mul 
             A 1 get B 1 get add 0.5 mul ] def
          /d C AB distance def
          [ A AB C d b c 0.5 mul ] ordered dup 5 get delta gt { stack stack-push }{
             [ exch aload pop pop pop pop ]
          } ifelse
          % otherwise leave it on the stack
          [ AB B C a d c 0.5 mul ] ordered dup 5 get delta gt { stack stack-push }{
             [ exch aload pop pop pop pop ]
          } ifelse
        }{

          a c div 0.5 le {
            /AC [ A 0 get C 0 get add 0.5 mul
                A 1 get C 1 get add 0.5 mul ] def
            /AB [ A 0 get B 0 get add 0.5 mul
                A 1 get B 1 get add 0.5 mul ] def
            /d C AB distance def
            [ A AB AC a 0.5 mul c 0.5 mul b 0.5 mul ] ordered dup 5 get delta gt { stack stack-push }{
             [ exch aload pop pop pop pop ]
          } ifelse
            [ AB C AC a d c 0.5 mul ]                 ordered dup 5 get delta gt { stack stack-push }{
             [ exch aload pop pop pop pop ]
          } ifelse
            [ AB B C b 0.5 mul a 0.5 mul d ]          ordered dup 5 get delta gt { stack stack-push }{
             [ exch aload pop pop pop pop ]
          } ifelse
          }{ % otherwise
            /AC [ A 0 get C 0 get add 0.5 mul
                A 1 get C 1 get add 0.5 mul ] def
            /AB [ A 0 get B 0 get add 0.5 mul
                A 1 get B 1 get add 0.5 mul ] def
            /BC [ B 0 get C 0 get add 0.5 mul
                B 1 get C 1 get add 0.5 mul ] def
            c 0.5 mul delta gt { 
              [ AC BC C a 0.5 mul b 0.5 mul c 0.5 mul ] stack stack-push 
              [ A C AC a 0.5 mul b 0.5 mul c 0.5 mul ] stack stack-push
              [ BC AC AB a 0.5 mul b 0.5 mul c 0.5 mul ] stack stack-push
              [ C C BC a 0.5 mul b 0.5 mul c 0.5 mul ] stack stack-push
			}{
              [AC BC C]
              [A C AC] 
              [BC AC AB] 
              [C C BC] 
            } ifelse
          } ifelse
        } ifelse
    } loop
  ]
end end } def

% --- main triangulation --------------------------------------

% monotone -  
% input: polygon array of 2D points
% output: array of polyon components

% monotone-triangulate -
% input: a monotone polygon
% output: an array of triangles

% subdivide -
% input: a triangle = array of 3 2D points
% output: an array of triangles

% a polygon P + delta -> array of triangles
/triangulation { triangulationdict begin
  1 dict begin
  /delta exch def
  /P exch def
  [ 
    P monotone  % array of polygons
    { % a monotone polygon P
      monotone-triangulate 
      { % [P Q R] 
        delta subdivide
        aload pop 
      } forall
    } forall
  ]
end end } def


