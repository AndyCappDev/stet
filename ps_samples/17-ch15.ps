/P [
[3 0.2]
[10.2 3.5]
[11 10.3]
[9 9.4]
[8 11]
[6.6 5.3]
[3 8.7]
[1.6 7]
[2 4.3]
[4.2 5.8]
[3 2]
[0.4 3]
] def


% - closing test.inc ------------------------

1 setlinejoin
1 setlinecap

gsave
currentlinewidth 1 mul setlinewidth
0 0 0 setrgbcolor
newpath
P dup length 1 sub get aload pop moveto
P {
  aload pop lineto
} forall
stroke
grestore

P monotone { 
  monotone-triangulate {
  /X exch def
    newpath
    X dup length 1 sub get aload pop moveto
    X {
      aload pop lineto
    } forall
    stroke
  } forall
} forall



