%%BeginDocument: images15/f3.eps
%!PS-Adobe-2-.0
%%BoundingBox: 0 0 108 112

% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------
[0 0 108 112]

% - Inserting bbox.inc ----------------------

% [llx lly urx ury] on loading

% defines global variables llx urx lly ury width height

aload pop
/ury exch def
/urx exch def
/lly exch def
/llx exch def
/width urx llx sub def
/height ury lly sub def

% llx lly urx ury 

/box { 4 dict begin
/ury exch def
/urx exch def
/lly exch def
/llx exch def
llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
closepath
end } def

/boundary {
llx lly urx ury box
} def

/center {
llx lly translate
width 2 div height 2 div translate
} def

% - closing bbox.inc ------------------------
newpath
boundary clip

width 2 div height 2 div translate

/S 32 def
S dup scale
1 S div setlinewidth

0.1 1.5 translate


% - Inserting F.inc ----------------------


/rad 0.08 def

/P [
  [0 0] % 0
  [0.25 -0.75]
  [-0.75 -1.75]
  [-0.1 -1.5] 
  [ 0.8  -1.5]
  [-0.5 -0.98] % 5
  [ 0.6 -1.65]
  [-0.5 -1.5]
  [-1.25 -1.75]
] def

% - closing F.inc ------------------------

/dx 0.4 def
/dy 0.9 def

/P [
[-1.5 -2.9]
[0 0] 
[0.20 dy neg]
[0.25 dx add dy -2 mul]
[0.25 dx add dx add dx add dy -2.7 mul]
] def

newpath
P 0 get aload pop moveto
1 1 P length 1 sub { 
  P exch get
  aload pop lineto
} for
gsave
0.9 setgray
fill
grestore
stroke

gsave
newpath
P 1 get aload pop 
rad 0 360 arc 
gsave
1 0 0 setrgbcolor
fill
grestore
stroke
grestore

gsave
newpath
P 2 get aload pop 
rad 0 360 arc 
gsave
1 0 0 setrgbcolor
fill
grestore
stroke
grestore

gsave
newpath
P 3 get aload pop 
rad 0 360 arc 
gsave
1 0 0 setrgbcolor
fill
grestore
stroke
grestore

gsave
newpath
P 4 get aload pop 
rad 0 360 arc 
gsave
1 0 0 setrgbcolor
fill
grestore
stroke
grestore


