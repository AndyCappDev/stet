%%BeginDocument: images15/case2.eps
%!PS-Adobe-2.0
%%BoundingBox: 0 0 120 100
[0 0 120 100]

% - Inserting bbox.inc ----------------------

% [llx lly urx ury] on loading

% defines global variables llx urx lly ury width height

aload pop
/ury exch def
/urx exch def
/lly exch def
/llx exch def
/width urx llx sub def
/height ury lly sub def

% llx lly urx ury 

/box { 4 dict begin
/ury exch def
/urx exch def
/lly exch def
/llx exch def
llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
closepath
end } def

/boundary {
llx lly urx ury box
} def

/center {
llx lly translate
width 2 div height 2 div translate
} def

% - closing bbox.inc ------------------------

newpath
boundary clip

gsave

12 16 translate

% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

/S 92 def
S dup scale
1 S div setlinewidth

gsave
1 0.6 dup setrgbcolor
newpath
0 0 1 0 30 arc
1 0 1 2 div 108 180 arc
gsave
1 0.9 dup setrgbcolor
fill
grestore
stroke
grestore

gsave
1 0.6 dup setrgbcolor
newpath
0.5 0 moveto
0 0 1 2 sqrt div 0 45 arc
gsave
1 setgray
fill
grestore
stroke
grestore

gsave
1 0.6 dup setrgbcolor
newpath
0.5 0 moveto
0 0 1 0 60 arc
closepath
stroke
grestore

/P [ 0.84 0.30 ] def

newpath
0 0 moveto
1 0 lineto
P aload pop lineto
closepath
stroke

newpath
P aload pop moveto
0.5 0 lineto
stroke

newpath
P 0 get 2 div P 1 get 2 div moveto
1 2 div 0 lineto
stroke

gsave
newpath
0.5 0
0.02 0 360 arc
gsave
0.5 setgray
fill
grestore
stroke
grestore

gsave
newpath
0 0
0.02 0 360 arc
gsave
1 setgray
fill
grestore
stroke
grestore

gsave
newpath
P 0 get 2 div P 1 get 2 div 
0.02 0 360 arc
gsave
0.5 setgray
fill
grestore
stroke
grestore

gsave
newpath
P aload pop 
0.02 0 360 arc
gsave
1 setgray
fill
grestore
stroke
grestore

gsave
newpath
1 0 
0.02 0 360 arc
gsave
1 setgray
fill
grestore
stroke
grestore

grestore

