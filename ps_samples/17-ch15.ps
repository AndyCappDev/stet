/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------
[ 0 0 96 96]

% - Inserting bbox.inc ----------------------

