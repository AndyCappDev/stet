% - Inserting hodgman-sutherland.inc ----------------------


% [A B C] = f, [x y] = P => Ax + By + C

/evaluate {  % [A B C] [x y]
  aload pop  % [A B C] x y
  3 2 roll      % x y [A B C]
  aload pop  % x y A B C
  5 1 roll      % C x y A B
  3 2 roll      % C x A B y
  mul           % C x A By
  3 1 roll      % C By x A
  mul           % C By Ax
  add add
} def

% polygon line => truncated polygon where f < 0

/hodgman-sutherland {
8 dict begin
/f exch def
/p   exch def
/n p length def
% P = p[n-1] to start
/P p n 1 sub get def
/fP f P evaluate def
[
  p {
    /Q exch def
    /fQ f Q evaluate def
    fP 0 lt {
      fQ 0 lt {
        % P & Q both out 
        Q
      }{
        % P out, Q in: put R on stack
        [
          fQ P 0 get mul fP Q 0 get mul sub fQ fP sub div
          fQ P 1 get mul fP Q 1 get mul sub fQ fP sub div
        ]
      } ifelse 
    } {  
      fQ 0 lt {
   	    % P in, Q out: R Q
        [
          fP Q 0 get mul fQ P 0 get mul sub fP fQ sub div
          fP Q 1 get mul fQ P 1 get mul sub fP fQ sub div
        ]
  	    Q
      } if
    } ifelse
    % else both out
    /P Q def
    /fP fQ def
  } forall
]
end
} def

/polygon-split {
8 dict begin
/f exch def
/p   exch def
/n p length def

/F [
  p {
    f exch evaluate
  } forall 
] def

% P = p[n-1] to start
/P p n 1 sub get def
/fP F n 1 sub get def
[
  0 1 n 1 sub { /i exch def
    /Q p i get def
    /fQ F i  get def
    fP 0 lt {
      fQ 0 lt {
        % P & Q both out 
        Q
      }{
        % P out, Q in: put R on stack
        [
          fQ P 0 get mul fP Q 0 get mul sub fQ fP sub div
          fQ P 1 get mul fP Q 1 get mul sub fQ fP sub div
        ]
      } ifelse 
    } {  
      fQ 0 lt {
   	    % P in, Q out: R Q
        [
          fP Q 0 get mul fQ P 0 get mul sub fP fQ sub div
          fP Q 1 get mul fQ P 1 get mul sub fP fQ sub div
        ]
  	    Q
      } if
    } ifelse
    % else both out
    /P Q def
    /fP fQ def
  } for
]

/P p n 1 sub get def
/fP F n 1 sub get def
[
  0 1 n 1 sub { /i exch def
    /Q p i get def
    /fQ F i  get def
    fP 0 gt {
      fQ 0 gt {
        % P & Q both out 
        Q
      }{
        % P out, Q in: put R on stack
        [
          fQ P 0 get mul fP Q 0 get mul sub fQ fP sub div
          fQ P 1 get mul fP Q 1 get mul sub fQ fP sub div
        ]
      } ifelse 
    } {  
      fQ 0 gt {
   	% P in, Q out: R Q
        [
          fP Q 0 get mul fQ P 0 get mul sub fP fQ sub div
          fP Q 1 get mul fQ P 1 get mul sub fP fQ sub div
        ]
  	Q
      } if
    } ifelse
    % else both out
    /P Q def
    /fP fQ def
  } for
]
end } def


% - closing hodgman-sutherland.inc ------------------------

72 dup scale
0.01 setlinewidth

/poly [
[-0.5 -0.5]
[0.5 -0.5]
[0.5 0.5]
[-0.5 0.5]
] def

/line [1.25 1 -0.5] def
/x0 -2 def
/x1  2 def
% y = -(Ax + C)/B
/y0 line 0 get x0 mul line 2 get add line 1 get div neg def
/y1 line 0 get x1 mul line 2 get add line 1 get div neg def

gsave
newpath
x0 y0 translate
y1 y0 sub
x1 x0 sub atan rotate
/b 0.5 def
/g 1 def
/dh -0.12 def
<< /ShadingType 4
/ColorSpace Duotone
/DataSource [

0 -4 0 1 b sub 0
0  6 0 1 b sub 0
0  -4 dh 1 g sub 0

0 -4 dh 1 g sub 0
0  6 dh 1 g sub 0
0  6 0 1 b sub 0
] >>
shfill
grestore

