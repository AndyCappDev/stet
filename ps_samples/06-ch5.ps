%%BeginDocument: images5/americanflag.eps
%!PS-Adobe-2.0
%%BoundingBox: 0 0 260 160 


% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

130 80 translate

0.5 0.5 scale

72 72 scale

0.024 setlinewidth

6.5 5 div dup scale

% do the red stripes

/width 5 def
/height 3 def
/h height 13 div def

width -0.5 mul height -0.5 mul translate

gsave
0 2 12 {
/i exch def
newpath
0 i h mul moveto
width 0 rlineto
0 h rlineto
width neg 0 rlineto
closepath
1 0 0 setrgbcolor 
fill
} for
grestore

% do the white stripes

gsave
1 2 9 {
/i exch def
newpath
0 i h mul moveto
width 0 rlineto
0 h rlineto
width neg 0 rlineto
closepath
1 setgray 
fill
} for
grestore

% do the blue field 

/bh h 7 mul def
/bw 2 def

newpath
0 height moveto
bw 0 rlineto
0 bh neg rlineto
bw neg 0 rlineto
closepath
0.2 setgray
fill

% now the stars: 5 x 6 + 4 x 5 = 50

% *   *   *   *   *   *
%   *   *   *   *   *
% *   *   *   *   *   *
%   *   *   *   *   *
% *   *   *   *   *   *
%   *   *   *   *   *
% *   *   *   *   *   *
%   *   *   *   *   *
% *   *   *   *   *   *

/star {
4 dict begin
/s exch def
% 90 234 -72 162 18
s 0 moveto
144 cos s mul 144 sin s mul lineto
-72 cos s mul -72 sin s mul lineto
 72 cos s mul 72 sin s mul lineto
-144 cos s mul -144 sin s mul lineto 
closepath
end
} def


/x bw 12 div def
/y bh 10 div def
/s y 0.42 mul def

gsave
1 setgray
0 height bh sub translate
x 1 mul y 1 mul translate

0 1 8 {
  /i exch def
  0 1 10 {
    /j exch def
    gsave
    % draw the star
    x j mul y i mul translate
    90 rotate
    i j add 2 mod 0 eq {
    	s star
    	fill
    } if
    grestore
  } for
} for

grestore

% outline in black

0 setgray
newpath
0 0 moveto
0 3 rlineto
5 0 rlineto
0 -3 rlineto
closepath
stroke


