%%BeginDocument: imagese/irrat0.eps
%!

%%BoundingBox: 0 0 56 56

% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

28 24 translate


% - Inserting irrat.inc ----------------------


/gamma 5 sqrt 1 add 0.5 mul def

% r
/pentagon {
4 dict begin
/r exch def
/t 18 def
[
5 {
[t cos r mul t sin r mul]
/t t 72 add def
} repeat
]
end
} def

% [ P0 P1 ... ]
/polypath {
4 dict begin
/p exch def
/n p length def
p n 1 sub get aload pop moveto
p {
aload pop lineto
} forall
end
} def

/r 0.30 def
/red { 0.8 0.8 0.8 } def
/green { 1 0.6 0.6 } def
/lightgrey { 0.8 0.8 0.8 } def
/black { 0 0 0 } def
/thin 0.012 def
/thick 0.036 def
/darkgrey 0.4 def
/dotrad 0.010 def
/verylightgrey { 1 1 1 } def

/page-setup {
72 dup scale
1.25 dup scale
thin setlinewidth
1 setlinecap
1 setlinejoin

% 3 3 translate 3 dup scale

} def

% P Q N

/dots {
8 dict begin
/N exch def
/Q exch def
/P exch def


drawingdict begin
Q P sub-2d 1 N div mul-2d 
end
/u exch def

gsave

P aload pop translate
N 1 add {
  newpath
  dotrad 0 moveto
  0 0 dotrad 0 360 arc
  closepath
  fill
  u aload pop translate
} repeat
 
grestore

end
} def


% - closing irrat.inc ------------------------

page-setup

/p r pentagon def

gsave
lightgrey setrgbcolor
newpath
p polypath
stroke
grestore

gsave
black setrgbcolor
newpath
p 0 get aload pop moveto
p 2 get aload pop lineto
stroke

newpath
p 4 get aload pop moveto
p 3 get aload pop lineto
stroke
grestore



