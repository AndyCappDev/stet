%%BeginDocument: imagese/fritz.eps
%!

%%BoundingBox: 0 0 300 292

150 128 translate

% - Inserting drawing.inc ----------------------

/drawingdict 10 dict def

drawingdict begin

/mul-2d {
2 dict begin
/c exch def	% [ [x y]
[ exch
aload pop	% [ x y
c mul exch c mul
exch
]
end
} def

/sub-2d {
2 dict begin
/P exch def
/Q exch def
[
Q 0 get P 0 get sub
Q 1 get P 1 get sub
]
end
} def


/add-2d {
2 dict begin
/Q exch def
/P exch def
[
Q 0 get P 0 get add
Q 1 get P 1 get add
]
end
} def


/dot-2d {
2 dict begin
/Q exch def
/P exch def
P 0 get Q 0 get mul
P 1 get Q 1 get mul
add
end
} def


/perp {
[ 
exch
aload pop
neg exch
]
} def

% [P0 Q0] [P1 Q1]

/segment-intersection {
6 dict begin
aload pop 
/Q1 exch def
/P1 exch def
aload pop
/Q0 exch def
/P0 exch def
/u Q1 P1 sub-2d perp def
/t 
  P1 P0 sub-2d u dot-2d  
  Q0 P0 sub-2d u dot-2d 
  div
def
P0 Q0 P0 sub-2d t mul-2d add-2d
end
} def

end

% --------------------------------------

false {

[0 1] [1 0] add-2d 

[[0 1][1 0]] [[0 0] [1 1]] segment-intersection ==

} if
% - closing drawing.inc ------------------------

% - Inserting irrat.inc ----------------------


/gamma 5 sqrt 1 add 0.5 mul def

% r
/pentagon {
4 dict begin
/r exch def
/t 18 def
[
5 {
[t cos r mul t sin r mul]
/t t 72 add def
} repeat
]
end
} def

% [ P0 P1 ... ]
/polypath {
4 dict begin
/p exch def
/n p length def
p n 1 sub get aload pop moveto
p {
aload pop lineto
} forall
end
} def

/r 0.30 def
/red { 0.8 0.8 0.8 } def
/green { 0.6 1 0.6 } def
/lightgrey { 0.8 0.8 0.8 } def
/black { 0 0 0 } def
/thin 0.012 def
/thick 0.036 def
/darkgrey 0.4 def
/dotrad 0.010 def
/verylightgrey { 1 1 1 } def

/page-setup {
72 dup scale
1.25 dup scale
thin setlinewidth
1 setlinecap
1 setlinejoin

% 3 3 translate 3 dup scale

} def

% P Q N

/dots {
8 dict begin
/N exch def
/Q exch def
/P exch def


drawingdict begin
Q P sub-2d 1 N div mul-2d 
end
/u exch def

gsave

P aload pop translate
N 1 add {
  newpath
  dotrad 0 moveto
  0 0 dotrad 0 360 arc
  closepath
  fill
  u aload pop translate
} repeat
 
grestore

end
} def


% - closing irrat.inc ------------------------

/r 1.5 def

gsave
page-setup

/p r pentagon def

newpath
p polypath
stroke

/star [
p 1 get
p 3 get
p 0 get
p 2 get
p 4 get
p 1 get
] def

newpath
star polypath
stroke

% - Inserting labels.pro ----------------------

