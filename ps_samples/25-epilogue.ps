P 1 get Q 1 get mul
add
end
} def


/perp {
[ 
exch
aload pop
neg exch
]
} def

% [P0 Q0] [P1 Q1]

/segment-intersection {
6 dict begin
aload pop 
/Q1 exch def
/P1 exch def
aload pop
/Q0 exch def
/P0 exch def
/u Q1 P1 sub-2d perp def
/t 
  P1 P0 sub-2d u dot-2d  
  Q0 P0 sub-2d u dot-2d 
  div
def
P0 Q0 P0 sub-2d t mul-2d add-2d
end
} def

end

% --------------------------------------

false {

[0 1] [1 0] add-2d 

[[0 1][1 0]] [[0 0] [1 1]] segment-intersection ==

} if
% - closing drawing.inc ------------------------

page-setup

/p r pentagon def

/r r gamma div gamma div def

/q [
[270         cos r mul 270         sin r mul]
[270  72 add cos r mul 270  72 add sin r mul]
[270 144 add cos r mul 270 144 add sin r mul]
[270 216 add cos r mul 270 216 add sin r mul]
[270 288 add cos r mul 270 288 add sin r mul]
] def

gsave
lightgrey setrgbcolor
newpath
p polypath
stroke
grestore

/N 3 def

gsave
lightgrey setrgbcolor
newpath
p 0 get aload pop moveto
q 2 get aload pop lineto
q 3 get aload pop moveto
p 2 get aload pop lineto
p 4 get aload pop lineto
p 1 get aload pop lineto
p 3 get aload pop lineto
p 0 get aload pop lineto
stroke
grestore

gsave
green setrgbcolor
thick setlinewidth
newpath
q 3 get aload pop moveto
q 2 get aload pop lineto
stroke
grestore

gsave
newpath
q 2 get q 3 get 3 dots
fill
grestore

gsave
green setrgbcolor
thick setlinewidth
newpath
q 4 get aload pop moveto
q 1 get aload pop lineto
stroke
grestore


/N 5 def

gsave
newpath
q 4 get q 1 get N dots
fill
grestore

gsave
newpath
q 3 get aload pop moveto
q 4 get aload pop lineto
