%%BeginDocument: imagese/irrat1.eps
%!

%%BoundingBox: 0 0 56 56

% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

28 24 translate


% - Inserting drawing.inc ----------------------

/drawingdict 10 dict def

drawingdict begin

/mul-2d {
2 dict begin
/c exch def	% [ [x y]
[ exch
aload pop	% [ x y
c mul exch c mul
exch
]
end
} def

/sub-2d {
2 dict begin
/P exch def
/Q exch def
[
Q 0 get P 0 get sub
Q 1 get P 1 get sub
]
end
} def


/add-2d {
2 dict begin
/Q exch def
/P exch def
[
Q 0 get P 0 get add
Q 1 get P 1 get add
]
end
} def


/dot-2d {
2 dict begin
/Q exch def
/P exch def
P 0 get Q 0 get mul
P 1 get Q 1 get mul
add
end
} def


/perp {
[ 
exch
aload pop
neg exch
]
} def

% [P0 Q0] [P1 Q1]

/segment-intersection {
6 dict begin
aload pop 
/Q1 exch def
/P1 exch def
aload pop
/Q0 exch def
/P0 exch def
/u Q1 P1 sub-2d perp def
/t 
  P1 P0 sub-2d u dot-2d  
  Q0 P0 sub-2d u dot-2d 
  div
def
P0 Q0 P0 sub-2d t mul-2d add-2d
end
} def

end

% --------------------------------------

false {

[0 1] [1 0] add-2d 

[[0 1][1 0]] [[0 0] [1 1]] segment-intersection ==

} if
