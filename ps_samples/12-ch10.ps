@urx 128 @ury 1080 @rwi @setspecial
%%BeginDocument: images10/euclid.eps
%!PS-Adobe-2.0
%%BoundingBox: 0 0 120 128

% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

/llx 0 def
/lly 0 def
/urx 120 def
/ury 128 def

/dx 1 def

gsave
newpath
dx dx moveto
urx dx 2 mul sub 0 rlineto
0 ury dx 2 mul sub rlineto
urx neg dx 2 mul add 0 rlineto
closepath
stroke
grestore

/dx 4 def

gsave
newpath
dx dx moveto
urx dx 2 mul sub 0 rlineto
0 ury dx 2 mul sub rlineto
urx neg dx 2 mul add 0 rlineto
closepath
stroke
grestore

35 60 translate

/a 3 def
/b 4 def
/c a dup mul b dup mul add sqrt def

10 dup scale
1 16 div setlinewidth

gsave
newpath
0 0 moveto
c 0 lineto
0 c neg rlineto
c neg 0 rlineto
closepath
gsave
0.2 setgray
fill
grestore
stroke
grestore

/x a a mul c div def
/y a b mul c div def
/T y neg x neg atan def

gsave
x y translate
T rotate
newpath
0 0 moveto
a 0 lineto
0 a neg rlineto
a neg 0 rlineto
closepath
gsave
1 0 0 setrgbcolor
fill
grestore
stroke
grestore

gsave
c 0 translate
y x c sub atan rotate
newpath
0 0 moveto
b 0 lineto
0 b neg rlineto
b neg 0 rlineto
closepath
gsave
0.6 setgray
fill
grestore
stroke
grestore

showpage




