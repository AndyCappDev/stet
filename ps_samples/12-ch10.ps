%%BeginDocument: images10/matrix-.eps
%!PS-Adobe-2.0
%%BoundingBox: 0 0 100 80

% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

-4 0 translate

/urx 100 def
/ury 80 def
/rx 101 24 sub def
/ry 57 22 sub def
/dA 35 26 sub def
/dB 53 25 sub def
/sx 5 def
/sy 3 def


/a urx 0.5 mul rx -0.5 mul add dA add sx add def
/b ury 0.5 mul ry -0.5 mul add dB add sy add def
/db 29 53 sub 2 div def
/da 87 35 sub 2 div def
/s db da div def
/dx da 4 div def
/dy dx s mul def
/dX dx 1.9 mul def
/dY dy 1.9 mul def
/A db da atan def

1 setlinecap

gsave

urx 8 add 2 translate
-1 1 scale

gsave
3 setlinewidth
0.8 setgray
newpath

a b moveto
dX dY rmoveto
dx dy rlineto

a da add b db add moveto
dX dY rmoveto
dx dy rlineto

a b db add moveto
dX dY rmoveto
dx dy rlineto

a da add b moveto
dX dY rmoveto
dx dy rlineto

% ---------------------------------------------------

gsave
% bottom arc 
a b db 2 mul add moveto
dX dY rmoveto
/h 2 da mul A cos mul 0.88 mul def
h A cos mul 
h A sin mul rlineto

/X0 a da 2 mul add dX add def
/Y0 b db add dY add def

/X1 a dX add h A cos mul add def
/Y1 b db 2 mul add dY add h A sin mul add def

/X2 X0 X1 add 0.5 mul def
/Y2 Y0 Y1 add 0.5 mul def

/r X1 X0 sub dup mul Y1 Y0 sub dup mul add sqrt 2 div def
X2 Y2 r A 90 sub A 90 add arc
stroke
grestore

% ---------------------------------------------------

gsave
% top arc
a da 2 mul add b moveto
/dX -7 def
/dY dX s mul def
dX dY rmoveto
h A cos mul neg
h A sin mul neg rlineto

/X0 a dX add def
/Y0 b db add dY add def

/X1 a da 2 mul add dX add h A cos mul sub def
/Y1 b dY add h A sin mul sub def

/X2 X0 X1 add 0.5 mul def
/Y2 Y0 Y1 add 0.5 mul def

/r X1 X0 sub dup mul Y1 Y0 sub dup mul add sqrt 2 div def
X2 Y2 r A 90 add A 90 sub arc
stroke
grestore
grestore

grestore

urx 2 div ury 2 div translate
rx -0.5 mul ry -0.5 mul translate


