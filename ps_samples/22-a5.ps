/originGray where {pop}{/originGray 0 def} ifelse
/locationGray where {pop}{/locationGray 0 def} ifelse
/focusGray where {pop}{/focusGray 0 def} ifelse
/crossGray where {pop}{/crossGray 0.8 def} ifelse

