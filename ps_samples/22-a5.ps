%%BeginDocument: imagesa5/pic2.eps
%!PS-Adobe
%%BoundingBox: 100 100 240 280

% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

/w 140 def


% - Inserting pages.inc ----------------------

% width * new points = 8*72 = 692 points
% width
/mkpage {
/page-width exch def
/s page-width 612 div def
s dup scale
1 s div setlinewidth
} def

/page-boundary {
0 0 moveto
612 0 rlineto
0 792 rlineto
-612 0 rlineto
closepath
} def

/inches {
72 dup mul
currentlinewidth 72 div setlinewidth
} def

/slw {
currentlinewidth mul setlinewidth
} def

/inches-grid {
1 1 8 { /i exch def
72 i mul 0 moveto
0 792 rlineto
} for

1 1 10 { /i exch def
0 i 72 mul moveto
612 0 rlineto
} for

} def

% - closing pages.inc ------------------------

100 104 translate

gsave
4 -4 translate
w mkpage
0.8 setgray
newpath
page-boundary
fill
grestore

gsave
w mkpage
newpath
page-boundary
gsave
0.92 setgray
fill
grestore
stroke

% - Inserting pic1.eps ----------------------

%!

gsave

8.5 36 mul 11 36 mul translate
/s 24 def

s dup scale
1 s div setlinewidth

/a 3 def
/b 4 def
/c a dup mul b dup mul add sqrt def
/x a dup mul c div def
/y a b mul c div def

gsave
newpath
0 0 moveto
c 0 rlineto
0 c neg rlineto
c neg 0 rlineto
closepath
stroke
grestore

gsave
x y translate
y neg x neg atan rotate
newpath
0 0 moveto
a 0 rlineto
0 a neg rlineto
a neg 0 rlineto
closepath
stroke
grestore

gsave
x y translate
y neg x neg atan rotate
180 rotate
newpath
0 0 moveto
b 0 rlineto
0 b neg rlineto
b neg 0 rlineto
closepath
stroke
grestore

gsave
newpath
0 0 moveto
x y lineto
0 c neg lineto
stroke
grestore

gsave
90 rotate
newpath
0 0 moveto
x y lineto
0 c neg lineto
stroke
grestore

/Helvetica-Bold findfont
/Symbol findfont
1 scalefont 
setfont
0.92 -4.5 moveto
(Eucleid) show

grestore






% - closing pic1.eps ------------------------
grestore


