%%BeginDocument: images3/threesquares.eps
%!PS-Adobe-2.0
%%BoundingBox: 0 0 120 156


% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

% - Inserting pages.inc ----------------------

% width * new points = 8*72 = 692 points
% width
/mkpage {
/page-width exch def
/s page-width 612 div def
s dup scale
1 s div setlinewidth
} def

/page-boundary {
0 0 moveto
612 0 rlineto
0 792 rlineto
-612 0 rlineto
closepath
} def

/inches {
72 dup mul
currentlinewidth 72 div setlinewidth
} def

/slw {
currentlinewidth mul setlinewidth
} def

/inches-grid {
1 1 8 { /i exch def
72 i mul 0 moveto
0 792 rlineto
} for

1 1 10 { /i exch def
0 i 72 mul moveto
612 0 rlineto
} for

} def

% - closing pages.inc ------------------------

1 setlinecap 
1 setlinejoin

120 mkpage

gsave
1 slw
0.4 setgray
newpath
page-boundary 
0.96 0.96 0.96 setrgbcolor
fill
grestore

gsave
0.84 setgray
newpath
inches-grid
% stroke
grestore

gsave
1 slw
0.4 setgray
newpath
page-boundary 
stroke
grestore

% --- the code -------------------------

72 72 scale
4.25 5.5 translate
1 72 div setlinewidth


% - Inserting lw.inc ----------------------

currentlinewidth 3.6 mul setlinewidth
% - closing lw.inc ------------------------

/s 1 def

/draw-square {
newpath
0 0 moveto
s 0 rlineto
0 s rlineto
s neg 0 rlineto
closepath
stroke
} def

draw-square
-1 -1 translate
draw-square
1 -1 translate
draw-square


