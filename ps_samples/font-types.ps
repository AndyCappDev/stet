%!PS-Adobe-3.0
%%Title: Font Types - demonstrates all supported font loading paths
%%Creator: PostForge
%%EndComments

% Layout constants
/margin 54 def
/fontsize 15 def
/lineheight 26 def
/ypos 738 def

% --- Helper procedures ---

% Show a section header in Helvetica-Bold
% string showheader -
/showheader {
    /ypos ypos 8 sub def
    /Helvetica-Bold findfont 13 scalefont setfont
    margin ypos moveto
    0.3 0.3 0.3 setrgbcolor
    show
    /ypos ypos lineheight sub def
    0 0 0 setrgbcolor
} def

% Show a font sample line: set the named font then print the description
% /FontName (type string) (location string) showfontline -
/showfontline {
    /loc exch def
    /ftype exch def
    /fname exch def

    % Try to load the font and check if it was substituted
    fname findfont
    dup /FontName get fname eq {
        % Font found - render in the requested font
        fontsize scalefont setfont
        margin ypos moveto
        ftype show ( - ) show
        fname 80 string cvs show
        ( - loaded from ) show
        loc show
    } {
        % Font was substituted - show NOT FOUND in the fallback font
        fontsize scalefont setfont
        margin ypos moveto
        0.6 0 0 setrgbcolor
        ftype show ( - ) show
        fname 80 string cvs show
        ( - NOT FOUND on this system) show
        0 0 0 setrgbcolor
    } ifelse

    /ypos ypos lineheight sub def
} def

% Separator line
/separator {
    0.75 setgray
    margin ypos 6 add moveto 558 ypos 6 add lineto stroke
    0 setgray
    /ypos ypos 6 sub def
} def

% === Page content ===

% Title
/Helvetica-Bold findfont 22 scalefont setfont
margin 756 moveto
(PostForge Font Type Demonstration) show

separator

% --- Type 1 from Font resource directory (.t1 files) ---
(Type 1 - Font Resource Directory) showheader

/NimbusRoman-Regular
    (Type 1) (resources/Font/) showfontline

/NimbusSans-Bold
    (Type 1) (resources/Font/) showfontline

separator

% --- Type 2 / CFF from system OTF fonts ---
(Type 2 \(CFF\) - System OTF Fonts) showheader

/Inconsolata
    (Type 2 / CFF) (system .otf) showfontline

/SourceCodePro-Regular
    (Type 2 / CFF) (system .otf) showfontline

separator

% --- Type 42 / TrueType from system TTF fonts ---
(Type 42 \(TrueType\) - System TTF Fonts) showheader

/LiberationSans
    (Type 42 / TrueType) (system .ttf) showfontline

/LiberationMono
    (Type 42 / TrueType) (system .ttf) showfontline

showpage
