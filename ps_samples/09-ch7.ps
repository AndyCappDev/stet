%%BeginDocument: images7/hyperbola.eps
%!PS-Adobe-2.0
%%BoundingBox: 0 0 200 150

% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------


% - Inserting box.inc ----------------------

% box.inc

/box {
2 dict begin

/h exch def
/w exch def

0 0 moveto
w 0 rlineto
0 h rlineto
w neg 0 rlineto
0 h neg rlineto
closepath

end
} def

/centred-box {
2 dict begin

/h exch def
/w exch def

w -0.5 mul h -0.5 mul moveto
w 0 rlineto
0 h rlineto
w neg 0 rlineto
0 h neg rlineto
closepath

end
} def

%[llx lly urx ury]

/rectangle {
4 dict begin

aload pop
/ury exch def
/urx exch def
/lly exch def
/llx exch def

llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
llx lly lineto
closepath

end
} def

% llx lly urx ury 

/bbox {
4 dict begin

/ury exch def
/urx exch def
/lly exch def
/llx exch def

llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
llx lly lineto
closepath

end
} def

/square {
1 dict begin

/s exch def

0 0 moveto
s 0 rlineto
0 s rlineto
s neg 0 rlineto
0 s neg rlineto
closepath
end
} def



% - closing box.inc ------------------------

% newpath 200 150 box stroke

100 24 translate

72 dup scale
1 72 div setlinewidth

% [sqrt(1 + x^2), x/sqrt(1 + x^2)]

/f {
2 dict begin
/x exch def
/y 1 x x mul add sqrt def
[
y
x y div 
]
end
} def

% x0 x1 N

/hyperbola {
8 dict begin
/N exch def
/x1 exch def
/x0 exch def

% h = (x1 - x0)/N
/h x1 x0 sub N div def

/x x0 def
/F x f def
/y F 0 get def
/s F 1 get def

x y moveto

N {
	x 0.33333 h mul add
	y h 0.33333 mul s mul add	
	/x x h add def
	/F x f def
	/y F 0 get def
	/s F 1 get def
	x h 0.33333 mul sub
	y h 0.33333 mul s mul sub
	x y
	curveto
} repeat

end
} def

0.75 0.75 scale

gsave
0.8 setgray
currentlinewidth 1.6 mul setlinewidth
newpath
-0.5 -0.5 moveto
2 2 lineto
-2 2 moveto
0.5 -0.5 lineto
stroke
grestore

gsave
1 0.8 dup setrgbcolor 
currentlinewidth 2 mul setlinewidth
newpath
-2 2 1 hyperbola
stroke
grestore

gsave
1 0 0 setrgbcolor
currentlinewidth 1 mul setlinewidth
newpath
-2 2 2 hyperbola
stroke
grestore

newpath
-2 2 4 hyperbola
stroke


