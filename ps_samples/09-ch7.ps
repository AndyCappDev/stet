%%BeginDocument: images7/logo7.eps
%!PS-Adobe-2.0
%%BoundingBox: 0 0 100 100

% - Inserting logo.inc ----------------------

%!

[ 0 0 100 100 ]

% - Inserting bbox.inc ----------------------

% [llx lly urx ury] on loading

% defines global variables llx urx lly ury width height

aload pop
/ury exch def
/urx exch def
/lly exch def
/llx exch def
/width urx llx sub def
/height ury lly sub def

% llx lly urx ury 

/box { 4 dict begin
/ury exch def
/urx exch def
/lly exch def
/llx exch def
llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
closepath
end } def

/boundary {
llx lly urx ury box
} def

/center {
llx lly translate
width 2 div height 2 div translate
} def

% - closing bbox.inc ------------------------


% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

% logo.inc

/h height 2 sub def
/w h 8.5 mul 11 div def
% page dimensions in points

width 0 translate
w neg 0 translate
-0.5 0.5 translate

/S 98 11 div def
S dup scale
1 S div setlinewidth

/page-boundary {
newpath
0 0 moveto
8.5 0 lineto
0 11 rlineto
0 11 lineto
closepath
} def





% - closing colours.inc ------------------------


% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

gsave
newpath
page-boundary 
clip

4.25 5.5 translate
2.5 dup scale
currentlinewidth 2.5 div setlinewidth

/f {
1 dict begin
/t exch def
/r t cos 4 exp t sin 4 exp add -0.25 exp def
r t cos mul r t sin mul
end
} def

/Helvetica-Bold findfont
0.5 scalefont
setfont

gsave
-0.9 0.16 translate
0.7 setgray
0 0 moveto
(curveto) show
0 0.5 moveto
(lineto) show
0 1 moveto
(moveto) show
0 -0.5 moveto
(stroke) show
0 -1 moveto
(fill) show
0 -1.5 moveto
(clip) show
grestore

/N 64 def
/t 0 def
/dt 360 N div def


newpath
t t f moveto
N {
  /t t dt add def
  t t f lineto
} repeat
clip

gsave
0.7 0 0 setrgbcolor
-0.9 0.16 translate
0 0 moveto
(curveto) show
0 0.5 moveto
(lineto) show
0 1 moveto
(moveto) show
0 -0.5 moveto
(stroke) show
0 -1 moveto
(fill) show
0 -1.5 moveto
(clip) show
grestore


/N 64 def
/t 0 def
/dt 360 N div def

newpath
t t f moveto
N {
  /t t dt add def
  t t f lineto
} repeat
stroke


grestore

gsave
currentlinewidth 1 mul setlinewidth
0.6 setgray
newpath
page-boundary 
stroke
grestore



