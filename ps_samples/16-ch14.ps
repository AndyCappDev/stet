% - Inserting cube.inc ----------------------

% cube.inc

/cv [
[0 0.5 sub 0 0.5 sub 0 0.5 sub ]
[0 0.5 sub 1 0.5 sub 0 0.5 sub ]
[1 0.5 sub 1 0.5 sub 0 0.5 sub ]
[1 0.5 sub 0 0.5 sub 0 0.5 sub ]
[0 0.5 sub 0 0.5 sub 1 0.5 sub ]
[0 0.5 sub 1 0.5 sub 1 0.5 sub ]
[1 0.5 sub 1 0.5 sub 1 0.5 sub ]
[1 0.5 sub 0 0.5 sub 1 0.5 sub ]
] def

/cube [
% face 0: -z > 0
[
  [
    cv 0 get
    cv 1 get
    cv 2 get
    cv 3 get
  ]
  dup normal-function 
]
% face 1: z - 1 > 0
[
  [
    cv 4 get
    cv 7 get
    cv 6 get
    cv 5 get
  ]
  dup normal-function 
]
% face 2: -y > 0
[
  [
    cv 0 get
    cv 3 get
    cv 7 get
    cv 4 get
  ]
  dup normal-function 
]
% face 3: y - 1 > 0
[
  [
    cv 1 get
    cv 5 get
    cv 6 get
    cv 2 get
  ]
  dup normal-function 
]
% face 4: -x > 0
[
  [
    cv 0 get
    cv 4 get
    cv 5 get
    cv 1 get
  ]
  dup normal-function 
]
% face 5: x - 1 > 0
[
  [
    cv 3 get
    cv 2 get
    cv 6 get
    cv 7 get
  ]
  dup normal-function 
]

] def

% - closing cube.inc ------------------------

/sc 32 def

/pb {
gsave
width 2 div height 2 div translate
sc dup scale
1 sc div setlinewidth
1 setlinejoin
1 setlinecap
} def

/pe {
grestore
showpage
} def

[0 0 6 1] set-eye
/dA 8 def
/A 17 def

pb

gsave3d
[0 1 0] A rotate3d

/E get-eye cim3d transform3d def
/light [-0.25 1 0.25 0 ] normalized cim3d transform3d def

/red [ 1 0 0 ] def
/pink [ 1 0.8 0.8] def

E 2 get 0 gt {
  /shift0 -1 def
  /shift1 1 def
  /c0 red def
  /c1 pink def
}{
  /shift0 1 def
  /shift1 -1 def
  /c1 red def
  /c0 pink def
} ifelse

gsave3d
0 0 shift0 translate3d
/E0 get-eye cim3d transform3d def
newpath
cube {
  % [ polygon normal ]
  aload pop 
  /N exch def
  /P exch def
  N E0 dot-product 0 ge {
    P P length 1 sub get 
    aload pop moveto3d
    P {
      aload pop lineto3d
    } forall
    gsave
    /s light N dot-product 1 add 2 div 0.6 mul 0.4 add def
    c0 0 get s mul c0 1 get s mul c0 2 get s mul setrgbcolor 
    fill
    grestore
    stroke
  } if
} forall
grestore3d

gsave3d
0 0 shift1 translate3d
/E1 get-eye cim3d transform3d def
newpath
cube {
  % [ polygon normal ]
  aload pop 
  /N exch def
  /P exch def
  N E1 dot-product 0 ge {
    P P length 1 sub get 
    aload pop moveto3d
    P {
      aload pop lineto3d
    } forall
    gsave
    /s light N dot-product 1 add 2 div 0.6 mul 0.4 add def
    c1 0 get s mul c1 1 get s mul c1 2 get s mul setrgbcolor 
    fill
    grestore
    stroke
  } if
} forall
grestore3d

pe

grestore3d


