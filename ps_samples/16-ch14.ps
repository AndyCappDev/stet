/page-end {
grestore
} def

/page-begin {
gsave
w 2 div h 2 div translate
0 -16 translate
72 dup scale
1 72 div setlinewidth
0.72 dup scale
} def

[0 0 5 1] set-eye

/A -60 def
/N 5 def
/n N 0.5 add def

page-begin
gsave3d
[1 0 0] A rotate3d
gsave
0.64 setgray
newpath
N neg 1 N { /i exch def
i n neg 0 moveto3d
i n 0 lineto3d
n neg i 0 moveto3d
n i 0 lineto3d
} for
stroke
grestore

gsave3d
1 0 0 translate3d
[0 0 1] 54 rotate3d

5 {
  newpath
  [0 0 1] 72 rotate3d
  36 sin 2 mul 0.06125 plainarrow3d
  36 sin 2 mul 0 0 translate3d
  gsave
  1 0 0 setrgbcolor
  fill
  grestore
  stroke
} repeat

grestore3d

gsave3d
[0 0 1] 90 rotate3d
[0 1 0] -90 rotate3d
newpath
1.6 0.05 plainarrow3d
fill
grestore3d

grestore3d
/A A 10 sub def
page-end


