% - Inserting shade.inc ----------------------


1 setlinejoin
1 setlinecap

16 16 translate

/llx 0 def
/lly 0 def
/urx 120 def
/ury 120 def

urx llx sub ury lly sub scale 
1 urx llx sub div setlinewidth

gsave
0.6 setgray
newpath
0 0 moveto
1 0 lineto
0 1 3 div moveto
1 1 3 div lineto
0 2 3 div moveto
1 2 3 div lineto
0 1 moveto
1 1 lineto

0 0 moveto
0 1 lineto
1 3 div 0 moveto
1 3 div 1 lineto
2 3 div 0 moveto
2 3 div 1 lineto
1 0 moveto
1 1 lineto
closepath

stroke
grestore

gsave

/Times-Roman findfont
0.08 scalefont
setfont

0 -0.1 moveto
-0.020 0 rmoveto
(0) show

0.4 -0.1 moveto
(Input) show

1 -0.1 moveto
-0.020 0 rmoveto
(1) show

