% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------
2 3 translate

/M 4 def
/N 6 def
/dx 36 def
/dy 36 def

gsave
0.72 setgray
newpath
0 1 N 1 sub { /i exch def
  0 1 M 1 sub { /j exch def
    gsave
      i dx mul j dy mul translate
      newpath
	  0 0 moveto
      dx 0 rlineto
      0 dy rlineto
      dx neg 0 rlineto
      0 dy neg rlineto
      closepath
      0 0 moveto
      dx dy rlineto
	  stroke
    grestore
  } for
} for
stroke
grestore

/Helvetica-Bold findfont
10 scalefont
setfont

/i 3 def
/j 2 def

i dx mul j dy mul translate

gsave
newpath
0 0 moveto
dx 0 rlineto
0 dy rlineto
dx neg 0 rlineto
0 dy neg rlineto
closepath
0 0 moveto
dx dy rlineto
stroke
grestore

gsave
-13 -10 moveto
(i, j) show
grestore

gsave
dx 0 moveto
3 -10 rmoveto
(i+1, j) show
grestore

gsave
0 dy moveto
-13 3 rmoveto
(i, j+1) show
grestore

gsave
dx dy moveto
3 3 rmoveto
(i+1, j+1) show
grestore

/rad 1.6 def

newpath
0 0 rad 0 360 arc fill
newpath
dx 0 rad 0 360 arc fill
newpath
0 dy rad 0 360 arc fill
newpath
dx dy rad 0 360 arc fill




