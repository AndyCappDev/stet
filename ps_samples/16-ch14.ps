%%BeginDocument: images14/bernstein.eps
%!PS-Adobe-2.0
%%BoundingBox: 0 0 144 144

% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

1 setlinejoin
1 setlinecap

16 16 translate

/llx 0 def
/lly 0 def
/urx 120 def
/ury 120 def

urx llx sub ury lly sub scale 
1 urx llx sub div setlinewidth

gsave
0.5 setgray
newpath
0 0 moveto
1 0 lineto
0 1 moveto
1 1 lineto
0 0 moveto
0 1 lineto
1 0 moveto
1 1 lineto
closepath

stroke
grestore

gsave
1 0.4 0.4 setrgbcolor
newpath
0 0 moveto
1 1 lineto
stroke
grestore


% - Inserting bernstein.inc ----------------------

%!

% t y=[ y0 y1 ... yn ]
/bernstein { % t y 
  % constants y n t s=1-t
  % variables k C P
  dup length % t y n+1
  1 sub      % t y n
  3 -1 roll 1 % y n t 1
  1 index sub % y n t s
  % constants in place
  1           % y n t s k
  3 index 3 index mul % y n t s k C=nt
  5 index 0 get       % y n t s k C P=y0
  5 index {           % y n t s k C P
    % P -> s.P + C.y[k]
    % C -> C.t.(n-k)/(k+1) 
    % k -> k+1
    3 index mul       % y n t s k C P.s
    1 index           % y n t s k C P.s C
    7 index           % y n t s k C P.s C y 
    4 index get mul add  % y n t s k C P.s+C.y[k]=new P
    3 1 roll          % y n t s P* k C
    5 index           % y n t s P* k C n
    2 index sub mul   % y n t s P* k C.(n-k)
    1 index 1 add div % y n t s P* k C.(n-k)/(k+1)
    4 index mul       % y n t s P* k C*
    3 1 roll 1 add    % y n t s C* P* k*
    3 1 roll          % y n t s k* C* P*
  } repeat
  7 1 roll 6 { pop } repeat
} def


% - closing bernstein.inc ------------------------

% - Inserting display.inc ----------------------

/display { 1 dict begin
  /n exch def
  n copy [ n 1 add 1 roll ] ==
end } def
% - closing display.inc ------------------------

/N 32 def
1 0 0 setrgbcolor
/dt 1 N div def
/t 0 def
newpath
t dup [ 0 1 3 div 2 3 div 1] bernstein moveto
N {
  /t t dt add def
  t dup [ 0 0 1 1] bernstein lineto
} repeat
stroke

/N 32 def
0.8 0 0 setrgbcolor
/dt 1 N div def
/t 0 def
newpath
t dup [ 0 1 3 div 2 3 div 1] bernstein moveto
N {
  /t t dt add def
  t dup [ 0 0 0 1 1 1] bernstein lineto
} repeat
stroke

/N 32 def
0.6 0 0 setrgbcolor
/dt 1 N div def
/t 0 def
newpath
t dup [ 0 1 3 div 2 3 div 1] bernstein moveto
N {
  /t t dt add def
  t dup [ 0 0 0 0 1 1 1 1] bernstein lineto
} repeat
stroke

0 setgray

