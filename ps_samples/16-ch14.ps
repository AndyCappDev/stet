%%BeginDocument: images14/gouraud.eps
%!PS-Adobe-2.0
%%BoundingBox: 0 0 76 66

% - Inserting devicen.colours.inc ----------------------

% b s -> 1-b, 1-b-s, dup
% x y y -> 1-x, x-y
% x 0 0 -> 1-x x
% x x x -> 1-x 0
% here x > y 

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% r g b should be r x x
/setrgbcolor {
  Duotone setcolorspace
  pop 
  1 2 index
  sub 
  3 1 roll 
  sub
  setcolor
} def

% g
/setgray {
  Duotone setcolorspace
  % g -> 1-g 0
  1 exch sub 0 
  setcolor
} def

/duotorgb { 1 dict begin % b s
/s exch def
/b exch def
1 b sub 
1 b sub s sub dup
end } def

/rgbtoduo { 1 dict begin % r g b
pop /y exch def
/x exch def
1 x sub x y sub 
end } def

% - closing devicen.colours.inc ------------------------

38 2 translate

72 dup scale
1 72 div setlinewidth

/A [0 3 sqrt 2 div] def
/B [ -0.5 0 ] def
/C [ 0.5 0 ] def

/ds [
  0 A aload pop 1 0
  0 B aload pop 0 1
  0 C aload pop 0 0   
] def

newpath
<<
  /ShadingType 4
  /ColorSpace Duotone
  /DataSource ds
>>
shfill

newpath
A aload pop moveto
B aload pop lineto
C aload pop lineto
closepath
stroke

