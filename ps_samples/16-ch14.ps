%%BeginDocument: bsp/squares4.eps
%!PS-Adobe-2.0
%%BoundingBox: 0 0 160 120

[0 0 160 120]

% - Inserting bbox.inc ----------------------

% [llx lly urx ury] on loading

% defines global variables llx urx lly ury width height

aload pop
/ury exch def
/urx exch def
/lly exch def
/llx exch def
/width urx llx sub def
/height ury lly sub def

% llx lly urx ury 

/box { 4 dict begin
/ury exch def
/urx exch def
/lly exch def
/llx exch def
llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
closepath
end } def

/boundary {
llx lly urx ury box
} def

/center {
llx lly translate
width 2 div height 2 div translate
} def

% - closing bbox.inc ------------------------

newpath
boundary 
clip

gsave

width 2 div height 2 div translate
13 rotate

/S 72 def
S dup scale
1 S div setlinewidth

/s 0.25 def

/square {
0 0 moveto
s 0 lineto
0 s rlineto
0 s lineto
closepath
} def

% -------------------------------------

gsave
0.2 0 translate 
newpath
square
stroke
grestore

gsave
0.3 -0.3 translate 
newpath
square
stroke
grestore

gsave
-0.2 0.2 translate 
newpath
square
stroke
grestore

gsave
-0.12 -0.1 translate 
newpath
square
stroke
grestore

gsave
-0.0 -0.4 translate 
newpath
square
stroke
grestore

% -------------------------------------


grestore





