% - Inserting epsetup.inc ----------------------

/page-begin {
  gsave
  w 0.5 mul h 0.5 mul translate
  72 dup scale
  1 72 div setlinewidth
  1 setlinecap
  1 setlinejoin
} def

/light [-0.25 1 0.2 0] def
/floor [0 1 0 3] def

/A 40 def

