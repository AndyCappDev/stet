  gsave
  w 0.5 mul h 0.5 mul translate
  /S 48 def
  S dup scale
  1 S div setlinewidth
  1 setlinecap
  1 setlinejoin
} def

/light [-0.25 1 0.2 0] def
/floor [0 1 0 3] def

/A 40 def

