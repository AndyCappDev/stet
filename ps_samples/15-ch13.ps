1 setlinecap

/S 17 def
S dup scale
1 S div 4 mul setlinewidth

[0 0 20 1] set-eye

-4 5 translate
5 -6 -5 translate3d
[0 1 0] 25 rotate3d

/s 5 def
/A 45 def
/E 8 def

/square [
[ s -2 div dup 0 ]
[ s  2 div s -2 div 0 ]
[ s  2 div dup 0 ] 
[ s -2 div s 2 div 0 ]
] def

/Z -16 def

gsave3d
0.0 0.0 Z translate3d
[0 1 0] A rotate3d
gsave
currentlinewidth 1 mul setlinewidth
newpath
square 0 get aload pop moveto3d
square 1 get aload pop lineto3d
square 2 get aload pop lineto3d
square 3 get aload pop lineto3d
closepath3d
stroke
grestore
grestore3d

gsave
1 0.7 0.7 setrgbcolor
currentlinewidth 2.4 div setlinewidth
newpath
0 1 3 { /i exch def
0 0 E moveto3d
gsave3d
0 0 E moveto3d
0.0 0.0 Z translate3d
[0 1 0] A rotate3d
square i get aload pop lineto3d
grestore3d
stroke
} for

gsave
0.7 setgray
/N 5 def
newpath
N neg 1 N { /i exch def
i N neg 0 moveto3d
i N 0 lineto3d
N neg i 0 moveto3d
N i 0 lineto3d
} for
stroke
grestore

gsave3d
currentlinewidth 1.6 mul setlinewidth
[0 0 1 0][0 0 E 1] plane-project
0.0 0.0 Z translate3d
[0 1 0] A rotate3d
gsave
1 0 0 setrgbcolor
currentlinewidth 1.25 mul setlinewidth
newpath
square 0 get aload pop moveto3d
square 1 get aload pop lineto3d
square 2 get aload pop lineto3d
square 3 get aload pop lineto3d
closepath3d
stroke
grestore
grestore3d

grestore


% - closing ps3d.inc ------------------------
grestore


grestore

gsave
currentlinewidth 1 mul setlinewidth
0.6 setgray
newpath
page-boundary 
stroke
grestore



