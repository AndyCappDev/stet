%%BeginDocument: images13/logo13.eps
%!PS-Adobe-2.0
%%BoundingBox: 0 0 100 100

% - Inserting logo.inc ----------------------

%!

[ 0 0 100 100 ]

% - Inserting bbox.inc ----------------------

% [llx lly urx ury] on loading

% defines global variables llx urx lly ury width height

aload pop
/ury exch def
/urx exch def
/lly exch def
/llx exch def
/width urx llx sub def
/height ury lly sub def

% llx lly urx ury 

/box { 4 dict begin
/ury exch def
/urx exch def
/lly exch def
/llx exch def
llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
closepath
end } def

/boundary {
llx lly urx ury box
} def

/center {
llx lly translate
width 2 div height 2 div translate
} def

% - closing bbox.inc ------------------------


% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

% logo.inc

/h height 2 sub def
/w h 8.5 mul 11 div def
% page dimensions in points

width 0 translate
w neg 0 translate
-0.5 0.5 translate

/S 98 11 div def
S dup scale
1 S div setlinewidth

/page-boundary {
newpath
0 0 moveto
8.5 0 lineto
0 11 rlineto
0 11 lineto
closepath
} def





% - closing colours.inc ------------------------


% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

gsave
newpath
page-boundary 
  clip


gsave
-4 0 translate
1 16 div dup scale

