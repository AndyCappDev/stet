%%BeginDocument: images13/behind3.eps
%!PS-Adobe-2.0
%%BoundingBox: 0 0 144 120

% - Inserting colours.inc ----------------------

% b s -> 1-b, 1-b-s
% x y -> 1-x, x-y

/Duotone
[
  /DeviceN
  [ (PANTONE Black CVC) (PANTONE 032 CVC) ]
  /DeviceRGB
  { % b s
    1 
    3 -1 roll
    sub 
    dup 3 -1 roll 
    sub dup 
  } 
] 
def

% - closing colours.inc ------------------------

[0 0 144 120] 

% - Inserting bbox.inc ----------------------

% [llx lly urx ury] on loading

% defines global variables llx urx lly ury width height

aload pop
/ury exch def
/urx exch def
/lly exch def
/llx exch def
/width urx llx sub def
/height ury lly sub def

% llx lly urx ury 

/box { 4 dict begin
/ury exch def
/urx exch def
/lly exch def
/llx exch def
llx lly moveto
urx lly lineto
urx ury lineto
llx ury lineto
closepath
end } def

/boundary {
llx lly urx ury box
} def

/center {
llx lly translate
width 2 div height 2 div translate
} def

% - closing bbox.inc ------------------------

boundary clip

gsave

center

/S 16 def
S dup scale
1 S div setlinewidth

-1 1 scale

-0 0 translate


% - Inserting behind.inc ----------------------


/e 3 def

% P = [x y]
/projection { 1 dict begin
aload pop 
/y exch def
/x exch def
[
  0
    e y mul 
    e x sub 
  div
]
end } def

% - closing behind.inc ------------------------

gsave
1 0.7 0.7 setrgbcolor 
newpath
12 0 moveto
-12 0 lineto
stroke
newpath
0 -12 moveto
0 12 lineto
stroke
grestore

/P0 [ -2 3 ] def
/P1 [ P0 0 get P0 1 get 1 sub ] def

gsave
0.6 setgray
newpath
P0 aload pop moveto
e 0 lineto
P1 aload pop lineto
stroke
grestore

gsave
currentlinewidth 2.5 mul setlinewidth
newpath
P0 aload pop moveto
P1 aload pop lineto
stroke
grestore

gsave
currentlinewidth 2.5 mul setlinewidth
newpath
P0 projection aload pop moveto
P1 projection aload pop lineto
stroke
grestore

newpath
e 0 0.032 0 360 arc
gsave
grestore
stroke

grestore


