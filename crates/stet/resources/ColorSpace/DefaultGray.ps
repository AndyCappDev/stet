%!PS-Adobe-3.0 Resource-ColorSpace
%%Title: DefaultGray
%%EndComments

% Default CIE substitute for DeviceGray when UseCIEColor is true.
% PLRM Section 6.2.5: DefaultGray must be CIEBasedA or [/DeviceGray].
% Uses CIEBasedA with D65 white point (sRGB gamma approximation).

[
    /CIEBasedA
    <<
        /WhitePoint [0.9505 1.0000 1.0890]  % D65 illuminant
        /BlackPoint [0.0000 0.0000 0.0000]
        /RangeA [0.0 1.0]

        % DecodeA: sRGB gamma linearization (gray → linear luminance)
        /DecodeA {
            dup 0.04045 lt
                { 12.92 div }
                { 0.055 add 1.055 div 2.4 exp }
            ifelse
        } bind

        % MatrixA: map linear gray to equal XYZ (D65 Y=1 luminance)
        /MatrixA [0.9505 1.0000 1.0890]

        /RangeLMN [0.0 0.9505 0.0 1.0000 0.0 1.0890]
    >>
]
